---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperienceCard from '../../components/ExperienceCard.astro';
import { getAllExperiences } from '../../lib/queries';

const experiences = await getAllExperiences();
---

<BaseLayout
  title="Le catalogue"
  description="Découvrez nos expériences immersives en réalité virtuelle — plus de 160 métiers à explorer, pour tous les publics."
>
  <!-- BARRE DE RECHERCHE -->
  <section class="catalogue-search-section" aria-label="Recherche">
    <div class="container">
      <div class="search-wrapper">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.6"/>
          <path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        <input
          id="catalogue-search"
          type="search"
          placeholder="Rechercher une expérience, un métier, une thématique…"
          autocomplete="off"
          aria-label="Rechercher dans le catalogue"
        />
      </div>
    </div>
  </section>

  <!-- GRILLE -->
  <section class="catalogue-grid-section">
    <div class="container">
      <ul class="catalogue-grid" id="catalogue-grid" role="list">
        {experiences.map(xp => (
          <li
            class="catalogue-grid-item"
            data-search={[
              xp.titre,
              xp.sousTitre,
              xp.descriptionCourte,
              xp.descriptionLongue,
              ...(xp.thematiques ?? []).map(t => t.titre),
              ...(xp.metiers ?? []).map(m => m.libelle),
            ].filter(Boolean).join(' ').toLowerCase()}
          >
            <ExperienceCard experience={xp} />
          </li>
        ))}
      </ul>

      <p class="catalogue-empty" id="catalogue-empty" hidden>
        Aucune expérience ne correspond à cette recherche.
        <button class="reset-btn" id="reset-search">Réinitialiser</button>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================
     RECHERCHE — sticky sous le header
     ============================================ */
  .catalogue-search-section {
    position: sticky;
    top: 100px;
    z-index: 10;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--m360-border);
    padding: var(--m360-space-5) 0;
  }

  .search-wrapper {
    position: relative;
    max-width: 680px;
    margin: 0 auto;
  }

  .search-icon {
    position: absolute;
    left: var(--m360-space-5);
    top: 50%;
    transform: translateY(-50%);
    color: var(--m360-text-caption);
    pointer-events: none;
  }

  #catalogue-search {
    width: 100%;
    padding: var(--m360-space-4) var(--m360-space-5) var(--m360-space-4) var(--m360-space-10);
    border: 1.5px solid var(--m360-border);
    border-radius: var(--m360-radius-pill);
    font-size: 15px;
    background: var(--m360-bg-neutral);
    color: var(--m360-text-body);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  #catalogue-search:focus {
    outline: none;
    border-color: var(--m360-blue);
    box-shadow: var(--m360-shadow-focus);
    background: #fff;
  }

  #catalogue-search::placeholder {
    color: var(--m360-text-caption);
  }

  /* ============================================
     GRILLE — 4 colonnes
     ============================================ */
  .catalogue-grid-section {
    padding: var(--m360-space-9) 0 var(--m360-space-16);
  }

  .catalogue-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--m360-space-5);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .catalogue-grid-item {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .catalogue-grid-item[hidden] {
    display: none;
  }

  .catalogue-grid-item > :global(.xp-card) {
    flex: 1;
  }

  /* ============================================
     ÉTAT VIDE
     ============================================ */
  .catalogue-empty {
    text-align: center;
    padding: var(--m360-space-16) 0;
    color: var(--m360-text-caption);
    font-size: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--m360-space-4);
  }

  .catalogue-empty[hidden] {
    display: none;
  }

  .reset-btn {
    background: none;
    border: none;
    color: var(--m360-blue);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: underline;
    padding: 0;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 967px) {
    .catalogue-search-section {
      top: 64px;
    }

    .catalogue-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--m360-space-4);
    }
  }

  @media (max-width: 639px) {
    .catalogue-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const searchInput = document.getElementById('catalogue-search') as HTMLInputElement;
  const items = document.querySelectorAll<HTMLLIElement>('.catalogue-grid-item');
  const emptyEl = document.getElementById('catalogue-empty') as HTMLElement;

  function applySearch(query: string) {
    const q = query.trim().toLowerCase();
    let visible = 0;

    items.forEach(item => {
      const text = item.dataset.search ?? '';
      const show = !q || text.includes(q);
      item.hidden = !show;
      if (show) visible++;
    });

    emptyEl.hidden = visible > 0;

    const qs = q ? `?q=${encodeURIComponent(q)}` : location.pathname;
    history.replaceState(null, '', qs);
  }

  // Restaurer depuis l'URL au chargement
  const initialQ = new URLSearchParams(location.search).get('q') ?? '';
  if (initialQ) {
    searchInput.value = initialQ;
    applySearch(initialQ);
  }

  // Debounce 200ms
  let timer: ReturnType<typeof setTimeout>;
  searchInput.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(() => applySearch(searchInput.value), 200);
  });

  document.getElementById('reset-search')?.addEventListener('click', () => {
    searchInput.value = '';
    applySearch('');
    searchInput.focus();
  });
</script>
