---
// src/pages/espace-client.astro
// Page hub Espace client — version consolidée (mai 2026).
//
// Composition :
// 1. Hero court avec CTA principal "Accéder au back-office" (lien externe)
// 2. 4 cartes d'accès rapide (3 externes + 1 ancre #support)
// 3. Actualités produit (3 derniers posts "Conseils" depuis Sanity)
// 4. Centre d'aide intégré (catégories → dossiers → articles, avec recherche)
//
// Note : page volontairement INDEXABLE pour capter la requête branded
// "espace client metiers360" sur Google.
//
// TODO — URLs externes à remplacer quand finalisées :
// - Back-office authentifié
// - Guide premier pas
// - Inscription formation débutante
// - Kit de communication

import BaseLayout from '../layouts/BaseLayout.astro';
import AccessCard from '../components/AccessCard.astro';
import { getBlogPostsByCategory, getAllSupportCategories } from '../lib/queries';

const conseilsPosts = await getBlogPostsByCategory('conseils');
const supportCategories = await getAllSupportCategories();

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}

// Centralisation des URLs pour un seul endroit à modifier plus tard
const URLS = {
  backOffice: 'https://backoffice.metiers360.com/',
  guidePremierPas: '#',      // TODO : URL Notion/Drive
  inscriptionFormation: '#', // TODO : URL inscription formation débutante
  kitCommunication: '#',     // TODO : URL kit de communication
};
---

<BaseLayout
  title="Espace client"
  description="Métiers 360 — Espace client. Accédez au back-office, aux ressources d'animation et au support technique."
>

  {/* ============================================
       HERO DEUX COLONNES — Texte gauche + photo back-office droite
       ============================================ */}
  <section class="ec-hero">
    <div class="ec-hero-inner">
      <div class="ec-hero-text">
        <p class="ec-hero-eyebrow">Espace client</p>
        <h1 class="ec-hero-title">
          Bienvenue dans votre espace <strong>Métiers&nbsp;360</strong>.
        </h1>
        <p class="ec-hero-lead">
          Accédez à votre back-office, aux ressources pour vos animations
          et à l'ensemble du support technique.
        </p>

        <a
          href={URLS.backOffice}
          class="ec-cta-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Accéder au back-office
          <span class="ec-cta-arrow" aria-hidden="true">↗</span>
        </a>
        <p class="ec-cta-note">Ouverture dans un nouvel onglet · Identifiants requis</p>
      </div>

      <div class="ec-hero-visual" aria-hidden="true">
        <img
          src="/images/backoffice.jpg"
          alt=""
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  {/* ============================================
       4 CARTES D'ACCÈS RAPIDE
       ============================================ */}
  <section class="ec-cards-section">
    <div class="ec-cards-inner">
      <h2 class="ec-cards-title">Vos accès rapides</h2>

      <div class="ec-cards-grid">
        <AccessCard
          href={URLS.guidePremierPas}
          icon="🚀"
          title="Guide premier pas"
          desc="Démarrer avec Métiers 360 — installation des casques, premières animations, retours d'expérience."
          arrow="Consulter"
          tone="blue"
          external={true}
          fresh="Essentiel"
        />

        <AccessCard
          href={URLS.inscriptionFormation}
          icon="🎓"
          title="Formation débutante"
          desc="Inscrivez vos équipes à notre formation d'introduction à l'animation Métiers 360."
          arrow="S'inscrire"
          tone="pink"
          external={true}
        />

        <AccessCard
          href={URLS.kitCommunication}
          icon="📣"
          title="Kit de communication"
          desc="Affiches, visuels, textes prêts à l'emploi pour faire connaître Métiers 360 à vos publics."
          arrow="Télécharger"
          tone="blue"
          external={true}
        />

        <AccessCard
          href="#support"
          icon="?"
          title="Centre d'aide"
          desc="FAQ, guides de dépannage et formulaire pour contacter notre équipe support."
          arrow="Accéder à l'aide"
          tone="pink"
        />
      </div>
    </div>
  </section>

  {/* ============================================
       FIL D'ACTUALITÉS PRODUIT — Placeholder visuel
       Le mécanisme Sanity est à recalibrer (publicCible supprimé).
       En attendant, on affiche la structure cible avec un état "vide".
       ============================================ */}
  <section class="ec-news-section">
    <div class="ec-news-inner">
      <header class="ec-news-header">
        <h2 class="ec-news-title">Actualités produit</h2>
        <a href="/blog" class="ec-news-link">Voir tout le blog →</a>
      </header>

      {conseilsPosts.length === 0 ? (
        <p class="ec-news-empty">Aucun article disponible pour le moment.</p>
      ) : (
        <div class="ec-news-grid">
          {conseilsPosts.slice(0, 3).map(post => (
            <a href={`/blog/${post.slug}`} class="ec-news-card">
              <div class="ec-news-card-img-wrap">
                {post.imageUrl
                  ? <img src={post.imageUrl} alt={post.imageAlt || post.titre} class="ec-news-card-img" loading="lazy" decoding="async" width="400" height="225" />
                  : <div class="ec-news-card-img-placeholder" aria-hidden="true" />
                }
              </div>
              <div class="ec-news-card-body">
                <p class="ec-news-card-titre">{post.titre}</p>
                {post.extrait && <p class="ec-news-card-extrait">{post.extrait}</p>}
                <time class="ec-news-card-date" datetime={post.datePublication}>
                  {formatDate(post.datePublication)}
                </time>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  {/* ============================================
       CENTRE D'AIDE INTÉGRÉ
       ============================================ */}
  <section class="ec-support-section" id="support">
    <div class="ec-support-inner">

      <header class="ec-support-header">
        <div class="ec-support-header-text">
          <h2 class="ec-support-title">Centre d'aide</h2>
          <p class="ec-support-subtitle">
            Trouvez rapidement la réponse à vos questions.
          </p>
        </div>
        <button class="ec-support-contact" data-open-contact-modal>
          Nous écrire
        </button>
      </header>

      <!-- Recherche -->
      <div class="ec-support-search-wrap">
        <svg class="ec-support-search-icon" width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.6"/>
          <path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        <input
          id="ec-search"
          type="search"
          placeholder="Rechercher dans l'aide…"
          autocomplete="off"
          aria-label="Rechercher dans le centre d'aide"
          class="ec-support-search"
        />
      </div>

      <!-- Catégories, dossiers, articles -->
      <div class="ec-support-body" id="ec-support-body">
        {supportCategories.map(cat => (
          <div class="ec-support-cat" data-cat-id={cat._id}>
            <h3 class="ec-support-cat-title">{cat.titre}</h3>

            <div class="ec-support-dossiers">
              {cat.dossiers.map(dossier => (
                <div class="ec-support-dossier" data-dossier-id={dossier._id}>
                  <h4 class="ec-support-dossier-title">{dossier.titre}</h4>
                  <ul class="ec-support-articles" role="list">
                    {dossier.articles.map(art => (
                      <li
                        data-search={`${art.titre} ${dossier.titre} ${cat.titre}`.toLowerCase()}
                      >
                        <a href={`/support/${art.slug}`} class="ec-support-article-link">
                          <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                            <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                          {art.titre}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        ))}

        <p class="ec-support-empty" id="ec-support-empty" hidden>
          Aucun résultat pour cette recherche.
        </p>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const searchInput = document.getElementById('ec-search') as HTMLInputElement | null;
  const emptyMsg    = document.getElementById('ec-support-empty') as HTMLElement | null;

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.trim().toLowerCase();
    let totalVisible = 0;

    document.querySelectorAll<HTMLElement>('.ec-support-cat').forEach(cat => {
      let catVisible = 0;

      cat.querySelectorAll<HTMLElement>('.ec-support-dossier').forEach(dossier => {
        let dossierVisible = 0;

        dossier.querySelectorAll<HTMLElement>('li[data-search]').forEach(li => {
          const match = !q || li.dataset.search!.includes(q);
          li.hidden = !match;
          if (match) dossierVisible++;
        });

        if (dossierVisible === 0) {
          dossier.setAttribute('data-hidden', '');
        } else {
          dossier.removeAttribute('data-hidden');
          catVisible += dossierVisible;
        }
      });

      if (catVisible === 0) {
        cat.setAttribute('data-hidden', '');
      } else {
        cat.removeAttribute('data-hidden');
        totalVisible += catVisible;
      }
    });

    if (emptyMsg) emptyMsg.hidden = totalVisible > 0;
  });
</script>

<style>
  /* ============================================
     HERO ESPACE CLIENT — 2 colonnes texte + photo
     ============================================ */
  .ec-hero {
    background: linear-gradient(180deg, var(--m360-blue-bg) 0%, #fff 100%);
    padding: var(--m360-space-14) var(--m360-space-8);
    overflow: hidden;
  }

  .ec-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--m360-space-12);
    align-items: center;
  }

  .ec-hero-text {
    text-align: left;
  }

  .ec-hero-eyebrow {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--m360-blue);
    margin: 0 0 var(--m360-space-5);
  }

  .ec-hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(36px, 4.5vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-5);
  }

  .ec-hero-title strong {
    color: var(--m360-blue);
    font-weight: inherit;
  }

  .ec-hero-lead {
    font-family: var(--font-heading);
    font-size: 18px;
    line-height: 1.5;
    color: var(--m360-text-body);
    margin: 0 0 var(--m360-space-9);
    max-width: 48ch;
  }

  .ec-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--m360-space-3);
    background: var(--m360-blue);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    padding: var(--m360-space-5) var(--m360-space-9);
    border-radius: var(--m360-radius-lg);
    text-decoration: none;
    box-shadow: var(--m360-shadow-blue);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .ec-cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--m360-shadow-blue-hover);
    text-decoration: none;
  }

  .ec-cta-arrow {
    font-size: 18px;
    transition: transform 0.2s ease;
  }

  .ec-cta-primary:hover .ec-cta-arrow {
    transform: translate(2px, -2px);
  }

  .ec-cta-note {
    font-size: 13px;
    color: var(--m360-text-caption);
    margin: var(--m360-space-4) 0 0;
  }

  /* Colonne photo back-office */
  .ec-hero-visual {
    border-radius: var(--m360-radius-card);
    overflow: hidden;
    box-shadow: var(--m360-shadow-lg);
    aspect-ratio: 3 / 2;
  }

  .ec-hero-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ============================================
     SECTION CARTES D'ACCÈS
     ============================================ */
  .ec-cards-section {
    padding: var(--m360-space-12) var(--m360-space-8);
    background: #fff;
  }

  .ec-cards-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ec-cards-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 32px);
    color: var(--m360-text-title);
    text-align: center;
    margin: 0 0 var(--m360-space-10);
    letter-spacing: -0.02em;
  }

  .ec-cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--m360-space-6);
  }

  /* ============================================
     SECTION FIL D'ACTUS — placeholder
     ============================================ */
  .ec-news-section {
    padding: var(--m360-space-12) var(--m360-space-8);
    background: var(--m360-bg-neutral);
  }

  .ec-news-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .ec-news-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--m360-space-4);
    margin-bottom: var(--m360-space-8);
  }

  .ec-news-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 32px);
    color: var(--m360-text-title);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ec-news-link {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    color: var(--m360-blue);
    text-decoration: none;
  }

  .ec-news-link:hover {
    text-decoration: underline;
  }

  .ec-news-empty {
    text-align: center;
    color: var(--m360-text-caption);
    font-size: 15px;
    padding: var(--m360-space-10) 0;
  }

  /* Grille 3 colonnes */
  .ec-news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--m360-space-6);
  }

  .ec-news-card {
    background: #fff;
    border: 1px solid var(--m360-border);
    border-radius: var(--m360-radius-2xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .ec-news-card:hover {
    box-shadow: var(--m360-shadow-lg);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .ec-news-card-img-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--m360-bg-neutral);
  }

  .ec-news-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ec-news-card:hover .ec-news-card-img {
    transform: scale(1.03);
  }

  .ec-news-card-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--m360-navy) 0%, var(--m360-blue) 100%);
  }

  .ec-news-card-body {
    padding: var(--m360-space-4) var(--m360-space-5) var(--m360-space-5);
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-2);
    flex: 1;
  }

  .ec-news-card-titre {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    color: var(--m360-text-title);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ec-news-card-extrait {
    font-size: 13px;
    color: var(--m360-text-caption);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .ec-news-card-date {
    font-size: 12px;
    color: var(--m360-text-caption);
    margin-top: auto;
    padding-top: var(--m360-space-2);
  }

  /* ============================================
     CENTRE D'AIDE INTÉGRÉ
     ============================================ */
  .ec-support-section {
    padding: var(--m360-space-14) var(--m360-space-8) var(--m360-space-16);
    background: #fff;
  }

  .ec-support-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .ec-support-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--m360-space-5);
    margin-bottom: var(--m360-space-8);
  }

  .ec-support-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 32px);
    color: var(--m360-text-title);
    letter-spacing: -0.02em;
    margin: 0 0 var(--m360-space-1);
  }

  .ec-support-subtitle {
    font-size: 15px;
    color: var(--m360-text-caption);
    margin: 0;
  }

  .ec-support-contact {
    background: var(--m360-blue);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    padding: var(--m360-space-3) var(--m360-space-6);
    border-radius: var(--m360-radius-lg);
    border: none;
    cursor: pointer;
    box-shadow: var(--m360-shadow-blue);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    white-space: nowrap;
  }

  .ec-support-contact:hover {
    transform: translateY(-1px);
    box-shadow: var(--m360-shadow-blue-hover);
  }

  /* Recherche */
  .ec-support-search-wrap {
    position: relative;
    margin-bottom: var(--m360-space-10);
  }

  .ec-support-search-icon {
    position: absolute;
    left: var(--m360-space-4);
    top: 50%;
    transform: translateY(-50%);
    color: var(--m360-text-caption);
    pointer-events: none;
  }

  .ec-support-search {
    width: 100%;
    padding: var(--m360-space-4) var(--m360-space-4) var(--m360-space-4) 42px;
    font-family: var(--font-heading);
    font-size: 15px;
    color: var(--m360-text-title);
    background: var(--m360-bg-neutral);
    border: 1px solid var(--m360-border);
    border-radius: var(--m360-radius-xl);
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    box-sizing: border-box;
  }

  .ec-support-search:focus {
    border-color: var(--m360-blue);
    box-shadow: 0 0 0 3px rgba(0, 100, 210, 0.1);
  }

  /* Grille catégories */
  .ec-support-body {
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-12);
  }

  .ec-support-cat-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(18px, 2vw, 22px);
    color: var(--m360-text-title);
    letter-spacing: -0.015em;
    margin: 0 0 var(--m360-space-6);
    padding-bottom: var(--m360-space-4);
    border-bottom: 2px solid var(--m360-blue);
  }

  /* Dossiers : grille 3 colonnes */
  .ec-support-dossiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--m360-space-6);
  }

  .ec-support-dossier {
    background: var(--m360-bg-neutral);
    border: 1px solid var(--m360-border);
    border-radius: var(--m360-radius-2xl);
    padding: var(--m360-space-5) var(--m360-space-6);
  }

  .ec-support-dossier-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--m360-text-caption);
    margin: 0 0 var(--m360-space-4);
  }

  .ec-support-articles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ec-support-article-link {
    display: flex;
    align-items: flex-start;
    gap: var(--m360-space-2);
    font-family: var(--font-heading);
    font-size: 13px;
    line-height: 1.45;
    color: var(--m360-text-body);
    text-decoration: none;
    padding: var(--m360-space-2) var(--m360-space-2);
    border-radius: var(--m360-radius-md);
    transition: background 0.12s ease, color 0.12s ease;
  }

  .ec-support-article-link svg {
    flex-shrink: 0;
    margin-top: 2px;
    opacity: 0.35;
    transition: opacity 0.12s ease;
  }

  .ec-support-article-link:hover {
    background: var(--m360-blue-bg);
    color: var(--m360-blue);
  }

  .ec-support-article-link:hover svg {
    opacity: 1;
  }

  /* Article masqué par la recherche */
  .ec-support-articles li[hidden] {
    display: none;
  }

  /* Dossier vide après recherche */
  .ec-support-dossier[data-hidden] {
    display: none;
  }

  /* Catégorie vide après recherche */
  .ec-support-cat[data-hidden] {
    display: none;
  }

  .ec-support-empty {
    text-align: center;
    color: var(--m360-text-caption);
    font-size: 15px;
    padding: var(--m360-space-8) 0;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 967px) {
    .ec-hero-inner {
      grid-template-columns: 1fr;
      gap: var(--m360-space-10);
    }
    .ec-hero-visual {
      max-width: 560px;
      margin: 0 auto;
      /* Pas d'order:-1 ici : on garde le texte AVANT la photo sur mobile.
         Pattern (b) validé avec Vincent : titre prioritaire au-dessus du fold. */
    }
  }

  @media (max-width: 1099px) {
    .ec-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 860px) {
    .ec-support-dossiers {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 639px) {
    .ec-hero {
      padding: var(--m360-space-12) var(--m360-space-5) var(--m360-space-10);
    }
    .ec-cards-section,
    .ec-news-section,
    .ec-support-section {
      padding-left: var(--m360-space-5);
