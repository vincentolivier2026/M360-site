---
// src/pages/espace-client.astro
// Page hub Espace client — version simplifiée du Sitemap V3.
//
// Composition :
// 1. Hero court avec CTA principal "Accéder au back-office" (lien externe)
// 2. 4 cartes d'accès rapide (3 externes + 1 interne support)
// 3. Placeholder visuel "Actualités produit à venir" (mécanisme Sanity à recalibrer)
// 4. Bloc final "Besoin d'aide ?" avec lien vers /support
//
// Note : page volontairement INDEXABLE pour capter la requête branded
// "espace client metiers360" sur Google.
//
// TODO — URLs externes à remplacer quand finalisées :
// - Back-office authentifié
// - Guide premier pas
// - Inscription formation débutante
// - Kit de communication

import BaseLayout from '../layouts/BaseLayout.astro';
import AccessCard from '../components/AccessCard.astro';
import { getBlogPostsByCategory } from '../lib/queries';

const conseilsPosts = await getBlogPostsByCategory('conseils');

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}

// Centralisation des URLs pour un seul endroit à modifier plus tard
const URLS = {
  backOffice: 'https://backoffice.metiers360.com/',
  guidePremierPas: '#',      // TODO : URL Notion/Drive
  inscriptionFormation: '#', // TODO : URL inscription formation débutante
  kitCommunication: '#',     // TODO : URL kit de communication
};
---

<BaseLayout
  title="Espace client"
  description="Métiers 360 — Espace client. Accédez au back-office, aux ressources d'animation et au support technique."
>

  {/* ============================================
       HERO DEUX COLONNES — Texte gauche + photo back-office droite
       ============================================ */}
  <section class="ec-hero">
    <div class="ec-hero-inner">
      <div class="ec-hero-text">
        <p class="ec-hero-eyebrow">Espace client</p>
        <h1 class="ec-hero-title">
          Bienvenue dans votre espace <strong>Métiers&nbsp;360</strong>.
        </h1>
        <p class="ec-hero-lead">
          Accédez à votre back-office, aux ressources pour vos animations
          et à l'ensemble du support technique.
        </p>

        <a
          href={URLS.backOffice}
          class="ec-cta-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Accéder au back-office
          <span class="ec-cta-arrow" aria-hidden="true">↗</span>
        </a>
        <p class="ec-cta-note">Ouverture dans un nouvel onglet · Identifiants requis</p>
      </div>

      <div class="ec-hero-visual" aria-hidden="true">
        <img
          src="/images/backoffice.jpg"
          alt=""
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  {/* ============================================
       4 CARTES D'ACCÈS RAPIDE
       ============================================ */}
  <section class="ec-cards-section">
    <div class="ec-cards-inner">
      <h2 class="ec-cards-title">Vos accès rapides</h2>

      <div class="ec-cards-grid">
        <AccessCard
          href={URLS.guidePremierPas}
          icon="🚀"
          title="Guide premier pas"
          desc="Démarrer avec Métiers 360 — installation des casques, premières animations, retours d'expérience."
          arrow="Consulter"
          tone="blue"
          external={true}
          fresh="Essentiel"
        />

        <AccessCard
          href={URLS.inscriptionFormation}
          icon="🎓"
          title="Formation débutante"
          desc="Inscrivez vos équipes à notre formation d'introduction à l'animation Métiers 360."
          arrow="S'inscrire"
          tone="pink"
          external={true}
        />

        <AccessCard
          href={URLS.kitCommunication}
          icon="📣"
          title="Kit de communication"
          desc="Affiches, visuels, textes prêts à l'emploi pour faire connaître Métiers 360 à vos publics."
          arrow="Télécharger"
          tone="blue"
          external={true}
        />

        <AccessCard
          href="/support"
          icon="?"
          title="Support technique"
          desc="FAQ, guides de dépannage et formulaire pour contacter notre équipe support."
          arrow="Obtenir de l'aide"
          tone="pink"
        />
      </div>
    </div>
  </section>

  {/* ============================================
       FIL D'ACTUALITÉS PRODUIT — Placeholder visuel
       Le mécanisme Sanity est à recalibrer (publicCible supprimé).
       En attendant, on affiche la structure cible avec un état "vide".
       ============================================ */}
  <section class="ec-news-section">
    <div class="ec-news-inner">
      <header class="ec-news-header">
        <h2 class="ec-news-title">Actualités produit</h2>
        <a href="/blog" class="ec-news-link">Voir tout le blog →</a>
      </header>

      {conseilsPosts.length === 0 ? (
        <p class="ec-news-empty">Aucun article disponible pour le moment.</p>
      ) : (
        <div class="ec-news-grid">
          {conseilsPosts.slice(0, 3).map(post => (
            <a href={`/blog/${post.slug}`} class="ec-news-card">
              <div class="ec-news-card-img-wrap">
                {post.imageUrl
                  ? <img src={post.imageUrl} alt={post.imageAlt || post.titre} class="ec-news-card-img" loading="lazy" decoding="async" width="400" height="225" />
                  : <div class="ec-news-card-img-placeholder" aria-hidden="true" />
                }
              </div>
              <div class="ec-news-card-body">
                <p class="ec-news-card-titre">{post.titre}</p>
                {post.extrait && <p class="ec-news-card-extrait">{post.extrait}</p>}
                <time class="ec-news-card-date" datetime={post.datePublication}>
                  {formatDate(post.datePublication)}
                </time>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  {/* ============================================
       BLOC "BESOIN D'AIDE ?" — lien support
       ============================================ */}
  <section class="ec-help-section">
    <div class="ec-help-inner">
      <h2 class="ec-help-title">Besoin d'aide ?</h2>
      <p class="ec-help-text">
        Notre équipe support répond à vos questions techniques et pédagogiques.
        Consultez la base de connaissances ou contactez-nous directement.
      </p>
      <div class="ec-help-actions">
        <a href="/support" class="ec-help-link">
          Aller à la page support <span aria-hidden="true">→</span>
        </a>
        <button class="ec-help-contact" data-open-contact-modal>
          Nous contacter
        </button>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================
     HERO ESPACE CLIENT — 2 colonnes texte + photo
     ============================================ */
  .ec-hero {
    background: linear-gradient(180deg, var(--m360-blue-bg) 0%, #fff 100%);
    padding: var(--m360-space-14) var(--m360-space-8);
    overflow: hidden;
  }

  .ec-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--m360-space-12);
    align-items: center;
  }

  .ec-hero-text {
    text-align: left;
  }

  .ec-hero-eyebrow {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--m360-blue);
    margin: 0 0 var(--m360-space-5);
  }

  .ec-hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(36px, 4.5vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-5);
  }

  .ec-hero-title strong {
    color: var(--m360-blue);
    font-weight: inherit;
  }

  .ec-hero-lead {
    font-family: var(--font-heading);
    font-size: 18px;
    line-height: 1.5;
    color: var(--m360-text-body);
    margin: 0 0 var(--m360-space-9);
    max-width: 48ch;
  }

  .ec-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--m360-space-3);
    background: var(--m360-blue);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    padding: var(--m360-space-5) var(--m360-space-9);
    border-radius: var(--m360-radius-lg);
    text-decoration: none;
    box-shadow: var(--m360-shadow-blue);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .ec-cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--m360-shadow-blue-hover);
    text-decoration: none;
  }

  .ec-cta-arrow {
    font-size: 18px;
    transition: transform 0.2s ease;
  }

  .ec-cta-primary:hover .ec-cta-arrow {
    transform: translate(2px, -2px);
  }

  .ec-cta-note {
    font-size: 13px;
    color: var(--m360-text-caption);
    margin: var(--m360-space-4) 0 0;
  }

  /* Colonne photo back-office */
  .ec-hero-visual {
    border-radius: var(--m360-radius-card);
    overflow: hidden;
    box-shadow: var(--m360-shadow-lg);
    aspect-ratio: 3 / 2;
  }

  .ec-hero-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ============================================
     SECTION CARTES D'ACCÈS
     ============================================ */
  .ec-cards-section {
    padding: var(--m360-space-12) var(--m360-space-8);
    background: #fff;
  }

  .ec-cards-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ec-cards-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 32px);
    color: var(--m360-text-title);
    text-align: center;
    margin: 0 0 var(--m360-space-10);
    letter-spacing: -0.02em;
  }

  .ec-cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--m360-space-6);
  }

  /* ============================================
     SECTION FIL D'ACTUS — placeholder
     ============================================ */
  .ec-news-section {
    padding: var(--m360-space-12) var(--m360-space-8);
    background: var(--m360-bg-neutral);
  }

  .ec-news-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .ec-news-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--m360-space-4);
    margin-bottom: var(--m360-space-8);
  }

  .ec-news-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 32px);
    color: var(--m360-text-title);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ec-news-link {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    color: var(--m360-blue);
    text-decoration: none;
  }

  .ec-news-link:hover {
    text-decoration: underline;
  }

  .ec-news-empty {
    text-align: center;
    color: var(--m360-text-caption);
    font-size: 15px;
    padding: var(--m360-space-10) 0;
  }

  /* Grille 3 colonnes */
  .ec-news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--m360-space-6);
  }

  .ec-news-card {
    background: #fff;
    border: 1px solid var(--m360-border);
    border-radius: var(--m360-radius-2xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .ec-news-card:hover {
    box-shadow: var(--m360-shadow-lg);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .ec-news-card-img-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--m360-bg-neutral);
  }

  .ec-news-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ec-news-card:hover .ec-news-card-img {
    transform: scale(1.03);
  }

  .ec-news-card-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--m360-navy) 0%, var(--m360-blue) 100%);
  }

  .ec-news-card-body {
    padding: var(--m360-space-4) var(--m360-space-5) var(--m360-space-5);
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-2);
    flex: 1;
  }

  .ec-news-card-titre {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    color: var(--m360-text-title);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ec-news-card-extrait {
    font-size: 13px;
    color: var(--m360-text-caption);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .ec-news-card-date {
    font-size: 12px;
    color: var(--m360-text-caption);
    margin-top: auto;
    padding-top: var(--m360-space-2);
  }

  /* ============================================
     SECTION "BESOIN D'AIDE ?"
     ============================================ */
  .ec-help-section {
    padding: var(--m360-space-12) var(--m360-space-8) var(--m360-space-14);
    background: #fff;
  }

  .ec-help-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    padding: var(--m360-space-12) var(--m360-space-8);
    background: var(--m360-blue-bg);
    border-radius: var(--m360-radius-card);
  }

  .ec-help-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 32px);
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-4);
    letter-spacing: -0.02em;
  }

  .ec-help-text {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--m360-text-body);
    margin: 0 auto var(--m360-space-7);
    max-width: 50ch;
  }

  .ec-help-actions {
    display: inline-flex;
    align-items: center;
    gap: var(--m360-space-6);
    flex-wrap: wrap;
    justify-content: center;
  }

  .ec-help-link {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    color: var(--m360-blue);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--m360-space-2);
  }

  .ec-help-link:hover {
    text-decoration: underline;
  }

  .ec-help-contact {
    background: var(--m360-blue);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    padding: var(--m360-space-4) var(--m360-space-7);
    border-radius: var(--m360-radius-lg);
    border: none;
    cursor: pointer;
    box-shadow: var(--m360-shadow-blue);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .ec-help-contact:hover {
    transform: translateY(-1px);
    box-shadow: var(--m360-shadow-blue-hover);
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 967px) {
    .ec-hero-inner {
      grid-template-columns: 1fr;
      gap: var(--m360-space-10);
    }
    .ec-hero-visual {
      max-width: 560px;
      margin: 0 auto;
      /* Pas d'order:-1 ici : on garde le texte AVANT la photo sur mobile.
         Pattern (b) validé avec Vincent : titre prioritaire au-dessus du fold. */
    }
  }

  @media (max-width: 1099px) {
    .ec-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 639px) {
    .ec-hero {
      padding: var(--m360-space-12) var(--m360-space-5) var(--m360-space-10);
    }
    .ec-cards-section,
    .ec-news-section,
    .ec-help-section {
      padding-left: var(--m360-space-5);
      padding-right: var(--m360-space-5);
    }
    .ec-cards-grid {
      grid-template-columns: 1fr;
      gap: var(--m360-space-4);
    }
    .ec-news-grid {
      grid-template-columns: 1fr;
    }
    .ec-help-inner {
      padding: var(--m360-space-9) var(--m360-space-5);
    }
    .ec-help-actions {
      flex-direction: column;
      gap: var(--m360-space-4);
    }
  }
</style>
