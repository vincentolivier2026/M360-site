---
// src/pages/plan-du-site.astro
// Plan du site — page accessoire requise par bonne pratique d'accessibilité.
// Liste hiérarchique de toutes les pages du site, par section.
//
// Source : Sitemap V3 figé.

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Plan du site"
  description="Plan du site Métiers 360 — accès rapide à toutes les pages."
>
  <article class="sitemap-page">
    <header class="sitemap-header">
      <p class="sitemap-eyebrow">Métiers 360</p>
      <h1 class="sitemap-title">Plan du site</h1>
      <p class="sitemap-subtitle">
        Toutes les pages du site, organisées par section. Pour une navigation
        plus rapide, utilisez le menu principal en haut de page.
      </p>
    </header>

    <div class="sitemap-grid">
      <section class="sitemap-section">
        <h2 class="sitemap-section-title">Accueil</h2>
        <ul class="sitemap-list">
          <li><a href="/">Accueil</a></li>
        </ul>
      </section>

      <section class="sitemap-section">
        <h2 class="sitemap-section-title">La solution</h2>
        <ul class="sitemap-list">
          <li><a href="/accompagnement">Accompagner vers l'emploi et la formation</a></li>
          <li><a href="/visibilite-metiers">Faire découvrir ses métiers</a></li>
        </ul>
      </section>

      <section class="sitemap-section">
        <h2 class="sitemap-section-title">Le catalogue</h2>
        <ul class="sitemap-list">
          <li><a href="/catalogue">Catalogue des expériences immersives</a></li>
        </ul>
      </section>

      <section class="sitemap-section">
        <h2 class="sitemap-section-title">Pages institutionnelles</h2>
        <ul class="sitemap-list">
          <li><a href="/a-propos">À propos</a></li>
          <li><a href="/pedagogie">Pédagogie</a></li>
          <li><a href="/references">Références</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </section>

      <section class="sitemap-section">
        <h2 class="sitemap-section-title">Espace client</h2>
        <ul class="sitemap-list">
          <li><a href="/espace-client">Espace client</a></li>
          <li><a href="/espace-client#support">Centre d'aide</a></li>
        </ul>
      </section>

      <section class="sitemap-section">
        <h2 class="sitemap-section-title">Mentions et conformité</h2>
        <ul class="sitemap-list">
          <li><a href="/mentions-legales">Mentions légales</a></li>
          <li><a href="/politique-confidentialite">Politique de confidentialité</a></li>
          <li><a href="/rse">Responsabilité sociale & environnementale</a></li>
          <li><a href="/inclusion-accessibilite">Inclusion & accessibilité</a></li>
        </ul>
      </section>
    </div>

    <p class="sitemap-note">
      Note : certaines pages sont encore en cours de construction et peuvent
      afficher temporairement une page d'erreur 404. Le site est en
      pré-production.
    </p>
  </article>
</BaseLayout>

<style>
  .sitemap-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: var(--m360-space-14) var(--m360-space-6) var(--m360-space-12);
  }

  .sitemap-header {
    margin-bottom: var(--m360-space-12);
    padding-bottom: var(--m360-space-8);
    border-bottom: 2px solid var(--m360-blue-bg);
  }

  .sitemap-eyebrow {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--m360-blue);
    margin: 0 0 var(--m360-space-4);
  }

  .sitemap-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-4);
  }

  .sitemap-subtitle {
    font-family: var(--font-heading);
    font-size: 17px;
    line-height: 1.5;
    color: var(--m360-text-caption);
    margin: 0;
    max-width: 60ch;
  }

  .sitemap-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--m360-space-10);
    margin-bottom: var(--m360-space-12);
  }

  .sitemap-section-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--m360-blue);
    margin: 0 0 var(--m360-space-4);
    padding-bottom: var(--m360-space-3);
    border-bottom: 1px solid var(--m360-border);
  }

  .sitemap-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-2);
  }

  .sitemap-list a {
    color: var(--m360-text-body);
    font-size: 16px;
    text-decoration: none;
    padding: var(--m360-space-2) 0;
    transition: color 0.15s ease;
    display: inline-flex;
    align-items: center;
    gap: var(--m360-space-2);
  }

  .sitemap-list a::before {
    content: '→';
    color: var(--m360-blue);
    flex-shrink: 0;
  }

  .sitemap-list a:hover {
    color: var(--m360-blue);
    text-decoration: none;
  }

  .sitemap-note {
    font-size: 14px;
    font-style: italic;
    color: var(--m360-text-caption);
    padding: var(--m360-space-5);
    background: var(--m360-bg-neutral);
    border-radius: var(--m360-radius-lg);
    border-left: 3px solid var(--m360-blue);
  }

  @media (max-width: 967px) {
    .sitemap-grid {
      grid-template-columns: 1fr;
      gap: var(--m360-space-7);
    }
  }

  @media (max-width: 639px) {
    .sitemap-page {
      padding: var(--m360-space-10) var(--m360-space-5) var(--m360-space-8);
    }
  }
</style>
