---
// src/pages/a-propos.astro
// Page "À propos" — V1 figée (2026-05-13)

import BaseLayout from '../layouts/BaseLayout.astro';
import PillarsBlock from '../components/PillarsBlock.astro';
import StatsBlock from '../components/StatsBlock.astro';
import EyebrowPill from '../components/EyebrowPill.astro';

const convictions = [
  {
    num: '01',
    title: 'Ne pas mentir sur les métiers',
    text: "Nous montrons les métiers dans leur vérité — les gestes, les environnements, les rythmes réels. La réalité virtuelle n'est pas pour nous un outil d'information de plus, c'est un déclencheur d'expérience et d'émotion. C'est ce qui éclaire les choix.",
  },
  {
    num: '02',
    title: 'Être utile au plus grand nombre',
    text: "Une solution qui demande une expertise technique pour fonctionner n'est utile à personne. Nous gommons la complexité, soignons l'accessibilité, et concevons nos contenus pour qu'ils s'utilisent dans toutes les structures, avec tous les publics.",
  },
  {
    num: '03',
    title: 'Faire parler, pas remplacer',
    text: "Un choix d'orientation se construit dans une série de conversations entre humains, pas avec une machine. Métiers 360 libère la parole, déclenche des questions, suscite des rencontres. L'immersion n'est jamais une fin en soi — c'est un point de départ pour le dialogue.",
  },
];

const timeline = [
  { year: '2016', text: 'Premiers travaux et recherches expérimentales.' },
  { year: '2018', text: 'Lancement de la première version en milieu scolaire.' },
  { year: '2019', text: 'Participation à l\'opération French Fab avec Pôle Emploi.' },
  { year: '2020', text: 'Déploiement national auprès des jeunes dans le cadre d\'<em>Un Jeune, une solution</em>. Lauréat du Trophée Oriane de la Région Île-de-France.' },
  { year: '2021', text: 'Prix des clients VivaTech pour le projet mené avec Manpower Talent Solutions.' },
  { year: '2022', text: 'Premières expériences interactives. Équipement d\'une partie des collèges et lycées de la Région Bourgogne-Franche-Comté.' },
  { year: '2023', text: 'Partenariat avec l\'OPCOmmerce pour l\'attractivité des métiers du commerce.' },
  { year: '2024', text: 'Plus de 100 Bureaux Information Jeunesse équipés partout en France.' },
  { year: '2025', text: 'Équipement national de la Journée Défense et Citoyenneté : une classe d\'âge complète touchée chaque année.' },
  { year: '2026', text: 'Première expérience immersive en <em>hand tracking</em>, en co-production avec la CMAR PACA.', current: true },
];

const stats = [
  { number: '300', label: 'métiers présents au catalogue', tone: 'blue' as const },
  { number: '2 200', label: 'structures équipées depuis 2018', tone: 'pink' as const },
  { number: '1,7M', label: 'immersions réalisées', tone: 'blue' as const },
];
---

<BaseLayout
  title="À propos"
  description="Métiers 360 met l'expérience immersive au service des choix d'orientation, du collège à la reconversion."
>

  <!-- ════════════════════════════════════════
       HERO
       ════════════════════════════════════════ -->
  <section class="ap-hero">
    <div class="ap-hero-inner">
      <EyebrowPill tone="pink">À propos</EyebrowPill>
      <h1 class="ap-hero-title">L'expérience change tout.</h1>
      <p class="ap-hero-lead">
        Choisir un métier, en changer, accompagner quelqu'un qui hésite : ce sont des décisions
        qui jalonnent toute une vie, du collège à la reconversion. Métiers&nbsp;360 met
        l'expérience immersive au service de ces choix, parce qu'on choisit mieux ce qu'on
        a déjà éprouvé.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       CE QUI NOUS FAIT AVANCER
       ════════════════════════════════════════ -->
  <PillarsBlock
    eyebrow="Ce qui nous fait avancer"
    title="Trois convictions qui guident tout ce que nous faisons."
    pillars={convictions}
  />

  <!-- ════════════════════════════════════════
       NOTRE PARCOURS — timeline
       ════════════════════════════════════════ -->
  <section class="timeline-section">
    <div class="timeline-inner">
      <header class="timeline-header">
        <EyebrowPill tone="blue">Notre parcours</EyebrowPill>
        <h2 class="timeline-title">Dix ans d'expériences et d'engagements.</h2>
      </header>

      <ol class="timeline" aria-label="Chronologie Métiers 360">
        {timeline.map(item => (
          <li class:list={['timeline-item', { 'timeline-item--current': item.current }]}>
            <div class="timeline-year" aria-label={`Année ${item.year}`}>
              {item.year}
            </div>
            <div class="timeline-dot" aria-hidden="true"></div>
            <p class="timeline-text" set:html={item.text} />
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       LE PROJET AUJOURD'HUI — stats
       ════════════════════════════════════════ -->
  <StatsBlock stats={stats} />

  <!-- Complément chiffres + ambition -->
  <section class="ap-today-section">
    <div class="ap-today-inner">
      <div class="ap-today-secondary">
        <div class="ap-today-stat">
          <span class="ap-today-number">9 500</span>
          <span class="ap-today-label">professionnels utilisateurs</span>
        </div>
        <div class="ap-today-stat">
          <span class="ap-today-number">11 500</span>
          <span class="ap-today-label">casques déployés</span>
        </div>
        <div class="ap-today-stat">
          <span class="ap-today-number">380</span>
          <span class="ap-today-label">codes ROME couverts</span>
        </div>
      </div>

      <p class="ap-today-ambition">
        Notre ambition&nbsp;: continuer à élargir la couverture du catalogue, accompagner
        toujours mieux les professionnels qui font le travail d'orientation au quotidien,
        et faire en sorte que l'expérience immersive devienne un réflexe partout où se
        construisent les choix de vie.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       POUR ALLER PLUS LOIN
       ════════════════════════════════════════ -->
  <section class="ap-links-section">
    <div class="ap-links-inner">
      <h2 class="ap-links-title">Pour aller plus loin</h2>
      <ul class="ap-links-list" role="list">
        <li>
          <a href="/equipe" class="ap-link">
            <span class="ap-link-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <circle cx="8" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="14" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M2 16c0-3 2.7-5 6-5s6 2 6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M14 14c1.5.5 3 1.5 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
              </svg>
            </span>
            <span>
              <strong>Notre équipe</strong>
              <em>Les personnes qui font Métiers 360</em>
            </span>
          </a>
        </li>
      </ul>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================
     HERO
     ============================================ */
  .ap-hero {
    background: var(--m360-navy);
    padding: var(--m360-space-16) var(--m360-space-8) var(--m360-space-14);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* Halos atmosphériques discrets */
  .ap-hero::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: var(--m360-blue);
    opacity: 0.08;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    filter: blur(80px);
    pointer-events: none;
  }

  .ap-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
  }

  .ap-hero-inner :global(.eyebrow) {
    margin-bottom: var(--m360-space-7);
    background: rgba(232, 181, 229, 0.15) !important;
    color: var(--m360-pink) !important;
  }

  .ap-hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 var(--m360-space-8);
  }

  .ap-hero-lead {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 auto;
    max-width: 62ch;
  }

  /* ============================================
     TIMELINE
     ============================================ */
  .timeline-section {
    padding: var(--m360-space-16) var(--m360-space-8);
    background: #fff;
  }

  .timeline-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .timeline-header {
    text-align: center;
    margin-bottom: var(--m360-space-14);
  }

  .timeline-header :global(.eyebrow) {
    margin-bottom: var(--m360-space-5);
  }

  .timeline-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(26px, 3.2vw, 38px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--m360-text-title);
    margin: 0;
  }

  /* Liste chronologique */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }

  /* Ligne verticale continue */
  .timeline::before {
    content: '';
    position: absolute;
    left: 88px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(to bottom, var(--m360-blue), var(--m360-pink));
    opacity: 0.25;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 80px 20px 1fr;
    gap: 0 var(--m360-space-6);
    align-items: start;
    padding-bottom: var(--m360-space-8);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  /* Année */
  .timeline-year {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 18px;
    color: var(--m360-text-caption);
    text-align: right;
    padding-top: 2px;
    line-height: 1.2;
    transition: color 0.2s ease;
  }

  .timeline-item--current .timeline-year {
    color: var(--m360-blue);
  }

  /* Point sur la ligne */
  .timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--m360-bg-neutral);
    border: 2px solid var(--m360-border);
    margin-top: 4px;
    justify-self: center;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .timeline-item--current .timeline-dot {
    background: var(--m360-blue);
    border-color: var(--m360-blue);
    transform: scale(1.3);
    box-shadow: 0 0 0 4px rgba(0, 128, 244, 0.15);
  }

  /* Texte */
  .timeline-text {
    font-size: 16px;
    line-height: 1.6;
    color: var(--m360-text-body);
    margin: 0;
    padding-top: 0;
  }

  .timeline-item--current .timeline-text {
    font-weight: 600;
    color: var(--m360-text-title);
  }

  .timeline-text :global(em) {
    font-style: italic;
    color: var(--m360-text-caption);
  }

  /* ============================================
     STATS SECONDAIRES + AMBITION
     ============================================ */
  .ap-today-section {
    padding: 0 var(--m360-space-8) var(--m360-space-16);
    background: #fff;
  }

  .ap-today-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .ap-today-secondary {
    display: flex;
    justify-content: center;
    gap: var(--m360-space-12);
    margin-bottom: var(--m360-space-12);
    padding-top: var(--m360-space-8);
    border-top: 1px solid var(--m360-border);
    flex-wrap: wrap;
  }

  .ap-today-stat {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-2);
  }

  .ap-today-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: -0.03em;
    color: var(--m360-navy);
    line-height: 1;
  }

  .ap-today-label {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    color: var(--m360-text-caption);
  }

  .ap-today-ambition {
    font-size: 17px;
    line-height: 1.75;
    color: var(--m360-text-body);
    max-width: 72ch;
    margin: 0 auto;
    text-align: center;
  }

  /* ============================================
     POUR ALLER PLUS LOIN
     ============================================ */
  .ap-links-section {
    padding: var(--m360-space-14) var(--m360-space-8) var(--m360-space-16);
    background: var(--m360-bg-neutral);
  }

  .ap-links-inner {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .ap-links-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 32px);
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-10);
    letter-spacing: -0.02em;
  }

  .ap-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-4);
    text-align: left;
  }

  .ap-link {
    display: flex;
    align-items: center;
    gap: var(--m360-space-5);
    background: #fff;
    border: 1px solid var(--m360-border);
    border-radius: var(--m360-radius-2xl);
    padding: var(--m360-space-5) var(--m360-space-6);
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .ap-link:hover {
    border-color: var(--m360-blue);
    box-shadow: var(--m360-shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .ap-link-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: var(--m360-radius-lg);
    background: var(--m360-blue-bg);
    color: var(--m360-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .ap-link:hover .ap-link-icon {
    background: var(--m360-blue);
    color: #fff;
  }

  .ap-link > span:last-child {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ap-link strong {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    color: var(--m360-text-title);
    display: block;
  }

  .ap-link em {
    font-style: normal;
    font-size: 13px;
    color: var(--m360-text-caption);
    display: block;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 639px) {
    .ap-hero {
      padding: var(--m360-space-12) var(--m360-space-5) var(--m360-space-10);
    }

    .ap-hero-lead {
      font-size: 16px;
    }

    .timeline-section {
      padding: var(--m360-space-12) var(--m360-space-5);
    }

    .timeline::before {
      left: 52px;
    }

    .timeline-item {
      grid-template-columns: 44px 16px 1fr;
      gap: 0 var(--m360-space-4);
    }

    .timeline-year {
      font-size: 15px;
    }

    .ap-today-section {
      padding: 0 var(--m360-space-5) var(--m360-space-12);
    }

    .ap-today-secondary {
      gap: var(--m360-space-8);
    }

    .ap-links-section {
      padding: var(--m360-space-12) var(--m360-space-5);
    }
  }
</style>
