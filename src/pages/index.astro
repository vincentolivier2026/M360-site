---
// src/pages/index.astro
// Home Métiers 360 — portage de Metiers360-Home-Maquette-V5b.html.
//
// Différences avec la maquette V5b source :
// - Refactor complet aux tokens V0.9 (plus aucune valeur littérale)
// - Header et Footer désormais dans BaseLayout (pas de duplication)
// - Chiffres mis à jour selon le référentiel officiel (skill chiffres-clefs-m360)
// - Embed YouTube en mode privacy enhanced (youtube-nocookie.com)
// - CTAs pointent vers les pages de la solution (cf. Sitemap V3)

import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import StatsBlock from '../components/StatsBlock.astro';
import PositioningBlock from '../components/PositioningBlock.astro';

const stats = [
  {
    number: '300',
    label: 'métiers présents au catalogue',
    tone: 'blue' as const,
  },
  {
    number: '2 200',
    label: 'structures équipées depuis 2018',
    tone: 'pink' as const,
  },
  {
    number: '1,7M',
    label: 'immersions réalisées',
    tone: 'blue' as const,
  },
];
---

<BaseLayout
  title="Métiers 360"
  description="Métiers 360 — La solution de référence pour la découverte des métiers en réalité virtuelle. 300 métiers au catalogue, 2 200 structures équipées."
>
  <HeroVideo
    youtubeId="sfv1e4CXw30"
    signature="L'expérience<br>change tout."
    ctaPrimary={{
      label: "J'accompagne vers l'emploi et la formation",
      href: '/accompagnement',
    }}
    ctaSecondary={{
      label: 'Je présente mes métiers',
      href: '/visibilite-metiers',
    }}
  />

  <StatsBlock stats={stats} />

  <PositioningBlock>
    <strong>Métiers 360</strong> est la solution de référence pour la découverte
    des métiers en réalité virtuelle. Nous équipons les structures qui accompagnent
    vers l'emploi et la formation, et nous co-produisons avec les organisations
    qui souhaitent rendre leurs métiers visibles.
  </PositioningBlock>
</BaseLayout>
