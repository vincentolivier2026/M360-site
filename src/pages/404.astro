---
// src/pages/404.astro
// Page d'erreur 404 — code HTTP 404 + meta noindex (cf. Sitemap V3 §2.1).
// Design provisoire, à enrichir avec le composant 404 du DS V0.7.

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page introuvable"
  description="Cette page n'existe pas ou a été déplacée."
  noindex={true}
>
  <section class="error-page">
    <div class="error-inner">
      <p class="error-code">404</p>
      <h1>Cette page n'existe pas.</h1>
      <p class="error-lead">
        Le lien que vous avez suivi est peut-être obsolète, ou la page a été déplacée.
      </p>
      <div class="error-actions">
        <a href="/" class="btn-primary">Retour à l'accueil</a>
        <a href="/catalogue" class="btn-link">Explorer le catalogue →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    padding: var(--m360-space-16) 0;
    text-align: center;
  }

  .error-inner {
    max-width: 560px;
    margin: 0 auto;
    padding: 0 var(--m360-space-6);
  }

  .error-code {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(80px, 15vw, 160px);
    line-height: 1;
    color: var(--m360-blue);
    margin: 0 0 var(--m360-space-4);
    opacity: 0.85;
  }

  .error-page h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 40px);
    margin: 0 0 var(--m360-space-4);
    color: var(--m360-text-title);
  }

  .error-lead {
    font-size: 17px;
    line-height: 1.6;
    color: var(--m360-text-body);
    margin: 0 0 var(--m360-space-8);
  }

  .error-actions {
    display: flex;
    gap: var(--m360-space-4);
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
  }

  .btn-primary {
    background: var(--m360-blue);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    padding: var(--m360-space-4) var(--m360-space-7);
    border-radius: var(--m360-radius-lg);
    text-decoration: none;
    box-shadow: var(--m360-shadow-blue);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--m360-shadow-blue-hover);
    text-decoration: none;
  }

  .btn-link {
    color: var(--m360-blue);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
  }

  .btn-link:hover {
    text-decoration: underline;
  }
</style>
