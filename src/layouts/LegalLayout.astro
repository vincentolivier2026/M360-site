---
// src/layouts/LegalLayout.astro
// Layout secondaire pour les 4 pages légales V2 :
// /mentions-legales, /politique-confidentialite, /rse, /inclusion-accessibilite
// Hérite de BaseLayout, ajoute une mise en forme typographique longue.

import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  /** Sous-titre / éditorial qui apparaît sous le titre H1 */
  subtitle?: string;
  /** Date de mise à jour ou mention de version */
  meta?: string;
}

const { title, description, subtitle, meta } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="legal-page">
    <header class="legal-header">
      {meta && <p class="legal-meta">{meta}</p>}
      <h1 class="legal-title">{title}</h1>
      {subtitle && <p class="legal-subtitle">{subtitle}</p>}
    </header>

    <div class="legal-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* ============================================
     LEGAL PAGE — typographie longue
     ============================================ */
  .legal-page {
    max-width: 760px;
    margin: 0 auto;
    padding: var(--m360-space-14) var(--m360-space-6) var(--m360-space-12);
  }

  .legal-header {
    margin-bottom: var(--m360-space-12);
    padding-bottom: var(--m360-space-8);
    border-bottom: 2px solid var(--m360-blue-bg);
  }

  .legal-meta {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--m360-blue);
    margin: 0 0 var(--m360-space-4);
  }

  .legal-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-4);
  }

  .legal-subtitle {
    font-family: var(--font-heading);
    font-size: 18px;
    line-height: 1.5;
    color: var(--m360-text-caption);
    margin: 0;
  }

  /* ============================================
     LEGAL CONTENT — règles globales
     ============================================ */
  .legal-content h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--m360-text-title);
    margin: var(--m360-space-12) 0 var(--m360-space-5);
    padding-top: var(--m360-space-6);
    border-top: 1px solid var(--m360-border);
  }

  .legal-content h2:first-child {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .legal-content h3 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 19px;
    line-height: 1.3;
    color: var(--m360-text-title);
    margin: var(--m360-space-8) 0 var(--m360-space-3);
  }

  .legal-content h4 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--m360-text-title);
    margin: var(--m360-space-6) 0 var(--m360-space-2);
  }

  .legal-content p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--m360-text-body);
    margin: 0 0 var(--m360-space-5);
    max-width: 70ch;
  }

  .legal-content strong {
    color: var(--m360-text-title);
    font-weight: 700;
  }

  .legal-content a {
    color: var(--m360-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .legal-content a:hover {
    text-decoration-thickness: 2px;
  }

  .legal-content ul {
    margin: 0 0 var(--m360-space-5);
    padding-left: var(--m360-space-6);
  }

  .legal-content ul li {
    font-size: 16px;
    line-height: 1.7;
    color: var(--m360-text-body);
    margin-bottom: var(--m360-space-2);
  }

  /* Tableaux dans les pages légales */
  .legal-content table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--m360-space-5) 0 var(--m360-space-8);
    font-size: 14px;
    border: 1px solid var(--m360-border);
    border-radius: var(--m360-radius-xl);
    overflow: hidden;
  }

  .legal-content table th,
  .legal-content table td {
    padding: var(--m360-space-3) var(--m360-space-4);
    text-align: left;
    border-bottom: 1px solid var(--m360-border);
    vertical-align: top;
  }

  .legal-content table th {
    background: var(--m360-blue-bg);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--m360-text-title);
    font-size: 13px;
  }

  .legal-content table tr:last-child td {
    border-bottom: none;
  }

  /* Encart de note (pour les éditoriaux des pages RSE/Inclusion) */
  .legal-callout {
    background: var(--m360-blue-bg);
    border-left: 4px solid var(--m360-blue);
    border-radius: 0 var(--m360-radius-lg) var(--m360-radius-lg) 0;
    padding: var(--m360-space-5) var(--m360-space-6);
    margin: var(--m360-space-6) 0 var(--m360-space-8);
    font-size: 17px;
    line-height: 1.6;
    color: var(--m360-text-title);
  }

  .legal-callout strong {
    color: var(--m360-text-title);
  }

  /* Bloc lauréat / distinction (page Inclusion) */
  .legal-award {
    display: inline-flex;
    align-items: center;
    gap: var(--m360-space-3);
    background: var(--m360-pink-bg);
    color: var(--m360-text-title);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    padding: var(--m360-space-3) var(--m360-space-5);
    border-radius: var(--m360-radius-pill);
    margin: var(--m360-space-6) 0;
  }
</style>
