---
// src/layouts/BaseLayout.astro
// Squelette HTML commun + intégration globale :
// - Plausible Analytics (chargé inconditionnellement, exempté CNIL)
// - Tarteaucitron (bandeau cookies)
// - ContactModal (modale Pipedrive avec lazy loading après consentement)

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  /** Empêche l'indexation de la page (pour /404 par exemple) */
  noindex?: boolean;
}

const {
  title,
  description = 'Métiers 360 — Faciliter la projection du plus grand nombre dans un futur professionnel désirable. 300 métiers en immersion 360°.',
  noindex = false,
} = Astro.props;

const fullTitle = title === 'Métiers 360'
  ? 'Métiers 360 — L\'expérience change tout'
  : `${title} — Métiers 360`;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph minimal */}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />

    {/* ====================================================
        PLAUSIBLE ANALYTICS — exempté de consentement CNIL
        Chargé inconditionnellement dans le <head>.
        Pas de cookie, pas de donnée identifiable.
        ==================================================== */}
    <script is:inline async src="https://plausible.io/js/pa-feyr7mM8efEpMVeo9PGw0.js"></script>
    <script is:inline>
      window.plausible = window.plausible || function() {
        (plausible.q = plausible.q || []).push(arguments);
      };
      plausible.init = plausible.init || function(i) { plausible.o = i || {}; };
      plausible.init();
    </script>
  </head>

  <body>
    <a href="#main" class="skip-link">Aller au contenu principal</a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    {/* Modale de contact — singleton, déclenchée par tout [data-open-contact-modal] */}
    <ContactModal />

    {/* Bandeau cookies Tarteaucitron — chargé en dernier */}
    <CookieBanner />
  </body>
</html>

<style>
  /* Skip link — accessibilité clavier */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: var(--m360-navy);
    color: #fff;
    padding: var(--m360-space-3) var(--m360-space-5);
    z-index: 9999;
    text-decoration: none;
    border-radius: 0 0 var(--m360-radius-md) 0;
  }
  .skip-link:focus {
    top: 0;
  }
</style>
