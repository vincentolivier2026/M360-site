---
// src/components/Header.astro
// Header sticky du site M360.
// Source : Sitemap V3 §8.1 + DS V0.12 (header système, hauteur 100px desktop / 64px mobile).
//
// FIX étape 4a-fix2 :
// - z-index renforcés : Header à 1000, drawer à 2000 (au-dessus de tous les contenus)
// - Drawer mobile pattern .is-open (au lieu de [hidden])
// - Accordéon La solution ouvert par défaut
---

<header class="site-header">
  <div class="header-inner">

    <a href="/" class="logo-link" aria-label="Métiers 360 — accueil">
      <img
        src="/logos/m360-logo.png"
        alt="Métiers 360"
        width="72"
        height="72"
        class="logo-img"
      />
    </a>

    {/* Navigation desktop — masquée sous 968px */}
    <nav class="nav-desktop" aria-label="Navigation principale">
      <a href="/catalogue" class="nav-link">Le catalogue</a>

      <div class="nav-dropdown">
        <button
          class="nav-link nav-dropdown-trigger"
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="solution-submenu"
        >
          La solution
          <svg width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
            <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </button>

        <div id="solution-submenu" class="nav-submenu" role="menu">
          <a href="/accompagnement" class="submenu-item" role="menuitem">
            <span class="submenu-eyebrow">Vous accompagnez des publics</span>
            <span class="submenu-title">Accompagner vers l'emploi et la formation</span>
            <span class="submenu-precision">Pour les écoles, CFA, OF, structures d'insertion, France Travail, collectivités.</span>
          </a>
          <a href="/visibilite-metiers" class="submenu-item" role="menuitem">
            <span class="submenu-eyebrow">Vous représentez un secteur</span>
            <span class="submenu-title">Faire découvrir ses métiers</span>
            <span class="submenu-precision">Pour les branches, OPCO, entreprises, filières territoriales.</span>
          </a>
          <a href="/solution-detail" class="submenu-item submenu-item--detail" role="menuitem">
            <span class="submenu-eyebrow">Vue d'ensemble</span>
            <span class="submenu-title">La solution en détail</span>
            <span class="submenu-precision">Casque, plateforme, modules, webapp — tout le dispositif.</span>
          </a>
        </div>
      </div>

      <a href="/espace-client" class="btn-outline">L'espace client</a>

      <button class="btn-primary" data-open-contact-modal>
        Nous contacter
      </button>
    </nav>

    {/* Actions mobile — visibles sous 968px */}
    <div class="nav-mobile-actions">
      <button class="btn-primary btn-compact" data-open-contact-modal>
        Contact
      </button>
      <button
        class="burger-btn"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

  </div>

  {/* Drawer mobile — fermé par défaut, ouvert via classe .is-open */}
  <div id="mobile-drawer" class="mobile-drawer">
    <div class="mobile-drawer-overlay" data-close-drawer></div>
    <div class="mobile-drawer-panel" role="dialog" aria-label="Menu de navigation" aria-modal="true">
      <div class="mobile-drawer-header">
        <img src="/logos/m360-logo.png" alt="Métiers 360" width="40" height="40" style="border-radius:50%" />
        <button class="drawer-close-btn" aria-label="Fermer le menu" data-close-drawer>×</button>
      </div>

      <nav class="mobile-drawer-nav" aria-label="Navigation principale mobile">
        <a href="/catalogue" class="mobile-link">Le catalogue</a>

        <details class="mobile-accordion" open>
          <summary class="mobile-link mobile-accordion-trigger">
            <span>La solution</span>
            <svg class="mobile-accordion-chevron" width="12" height="8" viewBox="0 0 12 8" aria-hidden="true">
              <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <div class="mobile-accordion-content">
            <a href="/accompagnement" class="mobile-sublink">Accompagner vers l'emploi et la formation</a>
            <a href="/visibilite-metiers" class="mobile-sublink">Faire découvrir ses métiers</a>
            <a href="/solution-detail" class="mobile-sublink">La solution en détail</a>
          </div>
        </details>

        <a href="/espace-client" class="mobile-link">L'espace client</a>
      </nav>

      <a href="#" class="mobile-drawer-cta" data-open-contact-modal>
        Nous contacter →
      </a>
    </div>
  </div>
</header>

<style>
  /* ============================================
     HEADER — z-index 1000 (au-dessus de tout contenu de page)
     ============================================ */
  .site-header {
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--m360-border);
    z-index: 1000;
  }

  .header-inner {
    max-width: var(--m360-bp-desktop);
    margin: 0 auto;
    padding: var(--m360-space-4) var(--m360-space-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--m360-space-8);
    height: 100px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: var(--m360-space-3);
    text-decoration: none;
    color: var(--m360-navy);
  }

  .logo-link:hover { text-decoration: none; }

  .logo-img {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    flex-shrink: 0;
    display: block;
  }

  /* ============================================
     NAV DESKTOP
     ============================================ */
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: var(--m360-space-7);
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 15px;
  }

  .nav-link {
    color: var(--m360-text-body);
    text-decoration: none;
    background: none;
    border: none;
    padding: var(--m360-space-2) 0;
    cursor: pointer;
    font: inherit;
    display: inline-flex;
    align-items: center;
    gap: var(--m360-space-1);
  }

  .nav-link:hover {
    color: var(--m360-blue);
    text-decoration: none;
  }

  /* ============================================
     SOUS-MENU "LA SOLUTION" (desktop)
     ============================================ */
  .nav-dropdown {
    position: relative;
  }

  .nav-submenu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 480px;
    background: #fff;
    border: 1px solid var(--m360-border);
    border-radius: var(--m360-radius-2xl);
    box-shadow: var(--m360-shadow-lg);
    padding: var(--m360-space-3);
    display: none;
    flex-direction: column;
    gap: var(--m360-space-2);
    /* Le sous-menu doit être au-dessus de tout */
    z-index: 1100;
  }

  /* Pont invisible entre le bouton et le sous-menu pour éviter les "trous"
     qui ferment le menu quand on traverse l'espace vide */
  .nav-submenu::before {
    content: '';
    position: absolute;
    top: -16px;
    left: 0;
    right: 0;
    height: 16px;
  }

  .nav-dropdown:hover .nav-submenu,
  .nav-dropdown:focus-within .nav-submenu {
    display: flex;
  }

  .submenu-item {
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-1);
    padding: var(--m360-space-4);
    border-radius: var(--m360-radius-xl);
    text-decoration: none;
    color: var(--m360-text-body);
    transition: background-color 0.15s ease;
    /* Garantit que les liens sont cliquables */
    position: relative;
    z-index: 1;
  }

  .submenu-item:hover {
    background: var(--m360-blue-bg);
    text-decoration: none;
  }

  .submenu-eyebrow {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--m360-blue);
  }

  .submenu-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    color: var(--m360-text-title);
  }

  .submenu-precision {
    font-size: 13px;
    color: var(--m360-text-caption);
    line-height: 1.5;
  }

  /* ============================================
     BOUTON PRIMAIRE (CTA)
     ============================================ */
  .btn-primary {
    background: var(--m360-blue);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    padding: var(--m360-space-4) var(--m360-space-7);
    border-radius: var(--m360-radius-lg);
    border: none;
    cursor: pointer;
    box-shadow: var(--m360-shadow-blue);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--m360-shadow-blue-hover);
  }

  .btn-primary.btn-compact {
    padding: var(--m360-space-3) var(--m360-space-5);
    font-size: 14px;
  }

  /* ============================================
     BOUTON SECONDAIRE OUTLINE — Espace client desktop
     Différencie l'accès utilitaire client du CTA commercial.
     ============================================ */
  .btn-outline {
    background: transparent;
    color: var(--m360-blue);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    padding: calc(var(--m360-space-4) - 1.5px) calc(var(--m360-space-7) - 1.5px);
    border-radius: var(--m360-radius-lg);
    border: 1.5px solid var(--m360-blue);
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: background-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
    line-height: 1;
  }

  .btn-outline:hover {
    background: var(--m360-blue-bg);
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* ============================================
     ACTIONS MOBILE
     ============================================ */
  .nav-mobile-actions {
    display: none;
    align-items: center;
    gap: var(--m360-space-3);
  }

  .burger-btn {
    width: 40px;
    height: 40px;
    background: var(--m360-navy);
    border-radius: var(--m360-radius-md);
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 0;
  }

  .burger-btn span {
    display: block;
    width: 18px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
  }

  /* ============================================
     DRAWER MOBILE — z-index 2000 (au-dessus de tout)
     ============================================ */
  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 2000;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, visibility 0s linear 0.2s;
  }

  .mobile-drawer.is-open {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.2s ease, visibility 0s linear 0s;
  }

  .mobile-drawer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(2, 31, 63, 0.4);
  }

  .mobile-drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    /* Hauteur explicite pour fiabiliser le calcul flex enfant.
       Sur Safari, top:0 + bottom:0 dans un parent fixed peut produire
       une hauteur calculée à 0 quand un ancêtre a position:sticky +
       backdrop-filter (cas du Header). 100vh + 100dvh résout ce piège. */
    height: 100vh;
    height: 100dvh; /* dynamic viewport height — fallback gracieux */
    width: 76%;
    max-width: 420px;
    background: #fff;
    box-shadow: var(--m360-shadow-drawer);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.25s ease-out;
  }

  .mobile-drawer.is-open .mobile-drawer-panel {
    transform: translateX(0);
  }

  .mobile-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--m360-space-5) var(--m360-space-6);
    border-bottom: 1px solid var(--m360-border);
    flex-shrink: 0;
  }

  .drawer-close-btn {
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    font-size: 28px;
    line-height: 1;
    color: var(--m360-text-title);
    cursor: pointer;
  }

  /* Drawer nav — bloc natif, les liens s'empilent comme du HTML standard */
  .mobile-drawer-nav {
    flex: 1 1 auto;
    padding: var(--m360-space-3) var(--m360-space-6);
    overflow-y: auto;
    /* Pas de display:flex ici : les enfants <a> et <details> doivent rester
       en flow normal pour que leur hauteur intrinsèque soit respectée.
       En flex avec flex:1 sur le parent, les flex items peuvent être
       compressés à 0 si flex-basis n'est pas explicite — c'était le bug. */
    min-height: 0; /* permet au flex parent (drawer-panel) de calculer correctement */
  }

  .mobile-drawer-nav .mobile-link {
    display: block;
    padding: var(--m360-space-4) 0;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 17px;
    color: var(--m360-text-title);
    text-decoration: none;
    border-bottom: 1px solid var(--m360-border);
  }

  .mobile-drawer-nav .mobile-link:hover {
    color: var(--m360-blue);
    text-decoration: none;
  }

  .mobile-accordion {
    border-bottom: 1px solid var(--m360-border);
  }

  .mobile-accordion summary {
    list-style: none;
    cursor: pointer;
    padding: var(--m360-space-4) 0;
    border-bottom: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mobile-accordion summary::-webkit-details-marker { display: none; }
  .mobile-accordion summary::marker { display: none; content: ''; }

  .mobile-accordion-chevron {
    transition: transform 0.2s ease;
    color: var(--m360-text-caption);
    flex-shrink: 0;
  }

  .mobile-accordion[open] .mobile-accordion-chevron {
    transform: rotate(180deg);
  }

  .mobile-accordion-content {
    padding: 0 0 var(--m360-space-4) var(--m360-space-4);
  }

  .mobile-accordion-content .mobile-sublink {
    display: block;
    padding: var(--m360-space-3) 0;
    font-size: 14px;
    color: var(--m360-text-body);
    text-decoration: none;
  }

  .mobile-accordion-content .mobile-sublink:hover {
    color: var(--m360-blue);
    text-decoration: none;
  }

  .mobile-drawer-cta {
    margin: var(--m360-space-5);
    padding: var(--m360-space-4);
    background: var(--m360-blue);
    color: #fff;
    text-align: center;
    border-radius: var(--m360-radius-lg);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    box-shadow: var(--m360-shadow-blue);
    flex-shrink: 0;
  }

  .mobile-drawer-cta:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* ============================================
     RESPONSIVE — bascule à 968px
     ============================================ */
  @media (max-width: 967px) {
    .header-inner {
      height: 64px;
      padding: var(--m360-space-3) var(--m360-space-5);
    }
    .logo-img {
      width: 60px;
      height: 60px;
    }
    .nav-desktop {
      display: none;
    }
    .nav-mobile-actions {
      display: flex;
    }
  }
</style>

<script>
  const burgerBtn = document.querySelector<HTMLButtonElement>('.burger-btn');
  const drawer = document.getElementById('mobile-drawer');
  const closeBtns = document.querySelectorAll('[data-close-drawer]');

  function openDrawer() {
    if (!drawer || !burgerBtn) return;
    drawer.classList.add('is-open');
    burgerBtn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    if (!drawer || !burgerBtn) return;
    drawer.classList.remove('is-open');
    burgerBtn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  burgerBtn?.addEventListener('click', openDrawer);
  closeBtns.forEach(btn => btn.addEventListener('click', closeDrawer));

  // Fermer le drawer après clic sur un lien
  drawer?.querySelectorAll('a[href]').forEach(link => {
    link.addEventListener('click', () => {
      setTimeout(closeDrawer, 100);
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('is-open')) {
      closeDrawer();
    }
  });

  // La gestion des boutons [data-open-contact-modal] est désormais
  // assurée par ContactModal.astro (inclus dans BaseLayout).
</script>
