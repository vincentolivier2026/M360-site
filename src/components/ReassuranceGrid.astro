---
// src/components/ReassuranceGrid.astro
// Bloc "Réassurance" — 4 items courts avec icônes SVG + encart financement.
// Source : Metiers360-Landing-Accompagnement-G3.html, bloc 6.

interface ReassuranceItem {
  iconKey: 'check' | 'globe' | 'people' | 'evolution';
  title: string;
  text: string;
}

interface FundingCard {
  title: string;
  /** Texte du paragraphe — supporte HTML pour les <strong> */
  text: string;
}

interface Props {
  items: ReassuranceItem[];
  funding?: FundingCard;
}

const { items, funding } = Astro.props;
---

<section class="reassurance-section">
  <div class="reassurance-inner">

    <div class="reassurance-grid">
      {items.map(item => (
        <div class="reassurance-item">
          <div class="reassurance-icon">
            {item.iconKey === 'check' && (
              <svg viewBox="0 0 56 56" width="56" height="56" aria-hidden="true">
                <circle cx="28" cy="28" r="22" fill="none" stroke="#0080F4" stroke-width="2.5"/>
                <path d="M 18 28 L 25 35 L 38 22" stroke="#021F3F" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {item.iconKey === 'globe' && (
              <svg viewBox="0 0 56 56" width="56" height="56" aria-hidden="true">
                <circle cx="28" cy="28" r="22" fill="#021F3F" opacity="0.9"/>
                <ellipse cx="28" cy="28" rx="22" ry="8" fill="none" stroke="#0080F4" stroke-width="2"/>
                <ellipse cx="28" cy="28" rx="8" ry="22" fill="none" stroke="#E8B5E5" stroke-width="2"/>
              </svg>
            )}
            {item.iconKey === 'people' && (
              <svg viewBox="0 0 56 56" width="56" height="56" aria-hidden="true">
                <circle cx="20" cy="28" r="14" fill="#0080F4" opacity="0.7"/>
                <circle cx="36" cy="28" r="14" fill="#E8B5E5" opacity="0.85"/>
              </svg>
            )}
            {item.iconKey === 'evolution' && (
              <svg viewBox="0 0 56 56" width="56" height="56" aria-hidden="true">
                <circle cx="28" cy="28" r="6" fill="#021F3F"/>
                <circle cx="14" cy="14" r="4" fill="#0080F4" opacity="0.85"/>
                <circle cx="42" cy="14" r="4" fill="#E8B5E5"/>
                <circle cx="42" cy="42" r="4" fill="#0080F4" opacity="0.85"/>
                <circle cx="14" cy="42" r="4" fill="#E8B5E5"/>
                <line x1="20" y1="20" x2="24" y2="24" stroke="#021F3F" stroke-width="1.5" opacity="0.4"/>
                <line x1="36" y1="20" x2="32" y2="24" stroke="#021F3F" stroke-width="1.5" opacity="0.4"/>
                <line x1="36" y1="36" x2="32" y2="32" stroke="#021F3F" stroke-width="1.5" opacity="0.4"/>
                <line x1="20" y1="36" x2="24" y2="32" stroke="#021F3F" stroke-width="1.5" opacity="0.4"/>
              </svg>
            )}
          </div>
          <div class="reassurance-item-title">{item.title}</div>
          <p class="reassurance-item-text">{item.text}</p>
        </div>
      ))}
    </div>

    {funding && (
      <div class="funding-card">
        <div class="funding-icon" aria-hidden="true">
          <svg viewBox="0 0 56 56" width="48" height="48">
            <circle cx="28" cy="28" r="22" fill="none" stroke="#0080F4" stroke-width="2.5"/>
            <text x="28" y="36" text-anchor="middle" font-family="Montserrat, sans-serif" font-weight="800" font-size="22" fill="#021F3F">€</text>
          </svg>
        </div>
        <div class="funding-content">
          <h3 class="funding-title">{funding.title}</h3>
          <p class="funding-text" set:html={funding.text}></p>
        </div>
      </div>
    )}

  </div>
</section>

<style>
  .reassurance-section {
    padding: var(--m360-space-14) var(--m360-space-8);
    background: #fff;
  }

  .reassurance-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  /* ============================================
     GRILLE 4 ITEMS
     ============================================ */
  .reassurance-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--m360-space-8);
    margin-bottom: var(--m360-space-12);
  }

  .reassurance-item {
    text-align: center;
  }

  .reassurance-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto var(--m360-space-4);
  }

  .reassurance-item-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    color: var(--m360-text-title);
    margin-bottom: var(--m360-space-2);
    line-height: 1.3;
  }

  .reassurance-item-text {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    color: var(--m360-text-caption);
    margin: 0;
    max-width: 22ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* ============================================
     ENCART FINANCEMENT
     ============================================ */
  .funding-card {
    display: flex;
    align-items: flex-start;
    gap: var(--m360-space-6);
    background: var(--m360-blue-bg);
    border-radius: var(--m360-radius-2xl);
    padding: var(--m360-space-8);
    border-left: 4px solid var(--m360-blue);
  }

  .funding-icon {
    flex-shrink: 0;
  }

  .funding-content {
    flex: 1;
  }

  .funding-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 19px;
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-3);
    line-height: 1.3;
  }

  .funding-text {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--m360-text-body);
    margin: 0;
    max-width: none;
  }

  .funding-text :global(strong) {
    color: var(--m360-text-title);
    font-weight: 700;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 967px) {
    .reassurance-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--m360-space-6);
    }
  }

  @media (max-width: 639px) {
    .reassurance-section {
      padding: var(--m360-space-10) var(--m360-space-5);
    }
    .reassurance-grid {
      grid-template-columns: 1fr;
      gap: var(--m360-space-7);
    }
    .funding-card {
      flex-direction: column;
      padding: var(--m360-space-6);
    }
  }
</style>
