---
// src/components/CookieBanner.astro
// Wrapper de configuration Tarteaucitron — bandeau cookies conforme CNIL.
//
// Services déclarés :
// - Pipedrive : consentement REQUIS (formulaires de contact, scripts tiers)
// - Plausible : exempté de consentement (chargé inconditionnellement dans BaseLayout)
//
// Tarteaucitron lui-même est servi depuis /tarteaucitron/ (téléchargé dans public/).
// Personnalisation visuelle via CSS pour matcher l'identité navy M360.
//
// Singleton : ce composant doit être inclus une seule fois dans BaseLayout.
---

<script is:inline src="/tarteaucitron/tarteaucitron.js"></script>

<script is:inline>
  // ============================================================
  // Configuration Tarteaucitron — au chargement de la page
  // ============================================================
  tarteaucitron.init({
    "privacyUrl": "/politique-confidentialite",
    "bodyPosition": "bottom",
    "hashtag": "#tarteaucitron",
    "cookieName": "tarteaucitron",
    "orientation": "bottom",
    "groupServices": false,
    "showDetailsOnClick": true,
    "serviceDefaultState": "wait",
    "showAlertSmall": true,
    "cookieslist": false,
    "closePopup": false,
    "showIcon": true,
    "iconPosition": "BottomLeft",
    "adblocker": false,
    "DenyAllCta": true,
    "AcceptAllCta": true,
    "highPrivacy": true,
    "handleBrowserDNTRequest": false,
    "removeCredit": false,
    "moreInfoLink": true,
    "useExternalCss": false,
    "useExternalJs": false,
    "readmoreLink": "/politique-confidentialite",
    "mandatory": true,
    "mandatoryCta": true
  });

  // ============================================================
  // Déclaration du service Pipedrive (custom)
  // Tarteaucitron ne propose pas Pipedrive en standard,
  // on le déclare en service custom.
  // ============================================================
  tarteaucitron.services.pipedrive = {
    "key": "pipedrive",
    "type": "support",
    "name": "Pipedrive (formulaires)",
    "uri": "https://www.pipedrive.com/fr/privacy",
    "needConsent": true,
    "cookies": [],
    "js": function () {
      // Le script Pipedrive est chargé dynamiquement par ContactModal
      // au moment où l'utilisateur ouvre la modale ET a consenti.
      // Rien à faire ici : on laisse ContactModal gérer l'injection
      // pour ne charger qu'à la demande.
    },
    "fallback": function () {
      // Idem : le fallback est géré par ContactModal (bloc consent-block)
    }
  };

  // On enregistre le service auprès de Tarteaucitron
  (tarteaucitron.job = tarteaucitron.job || []).push('pipedrive');
</script>

<style is:global>
  /* ============================================
     Personnalisation Tarteaucitron — identité M360
     ============================================ */

  /* Conteneur racine — barre plein-largeur en bas */
  #tarteaucitronRoot {
    position: fixed !important;
    bottom: 0 !important;
    left: 0 !important;
    right: 0 !important;
    z-index: 9000 !important;
  }

  /* Titre sr-only injecté par Tarteaucitron pour l'a11y — masquer visuellement */
  #dialogTitle,
  #tarteaucitronAlertBig .tarteaucitronH1.sr-only,
  #tarteaucitronAlertBig [class*="sr-only"] {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0,0,0,0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  /* Bandeau principal — plein-largeur, fond navy */
  #tarteaucitronAlertBig {
    background: var(--m360-navy) !important;
    color: #fff !important;
    border-radius: 0 !important;
    box-shadow: 0 -4px 24px rgba(2,31,63,0.18) !important;
    padding: var(--m360-space-5) var(--m360-space-8) !important;
    font-family: var(--font-body) !important;
    font-size: 14px !important;
    line-height: 1.6 !important;
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    flex-wrap: wrap !important;
    gap: var(--m360-space-4) !important;
    box-sizing: border-box !important;
  }

  #tarteaucitronAlertBig strong {
    color: #fff !important;
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
  }

  #tarteaucitronAlertBig a {
    color: #45ABFF !important;
    text-decoration: underline !important;
  }

  /* Conteneur des boutons du bandeau */
  #tarteaucitronAlertBig #tarteaucitronAlertBigBottom {
    display: flex !important;
    gap: var(--m360-space-3) !important;
    flex-wrap: wrap !important;
    flex-shrink: 0 !important;
  }

  /* Boutons du bandeau */
  #tarteaucitronAlertBig button,
  #tarteaucitronAlertBig .tarteaucitronCTAButton,
  #tarteaucitronCloseAlert,
  #tarteaucitronPersonalize,
  #tarteaucitronAllAllowed,
  #tarteaucitronAllDenied {
    background: var(--m360-blue) !important;
    color: #fff !important;
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
    font-size: 14px !important;
    padding: var(--m360-space-3) var(--m360-space-5) !important;
    border-radius: var(--m360-radius-lg) !important;
    border: none !important;
    box-shadow: var(--m360-shadow-blue) !important;
    cursor: pointer !important;
    transition: transform 0.15s ease !important;
    white-space: nowrap !important;
  }

  #tarteaucitronAlertBig button:hover,
  #tarteaucitronCloseAlert:hover,
  #tarteaucitronAllAllowed:hover {
    transform: translateY(-1px) !important;
  }

  /* Bouton "Personnaliser" et "Politique de confidentialité" en outline */
  #tarteaucitronPersonalize,
  #tarteaucitronCloseAlert.tarteaucitronCTAButton {
    background: rgba(255,255,255,0.1) !important;
    border: 1px solid rgba(255,255,255,0.3) !important;
    box-shadow: none !important;
  }

  /* Bouton "Tout refuser" en outline */
  #tarteaucitronAllDenied {
    background: rgba(255,255,255,0.1) !important;
    border: 1px solid rgba(255,255,255,0.3) !important;
    box-shadow: none !important;
  }

  /* Icône flottante en bas à gauche */
  #tarteaucitronRoot #tarteaucitronAlertSmall {
    background: var(--m360-navy) !important;
    color: #fff !important;
    border-radius: var(--m360-radius-pill) !important;
    box-shadow: var(--m360-shadow-md) !important;
    padding: var(--m360-space-3) var(--m360-space-4) !important;
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
    font-size: 13px !important;
  }

  /* Panneau de gestion détaillé */
  #tarteaucitron {
    background: #fff !important;
    border-radius: var(--m360-radius-card) !important;
    box-shadow: var(--m360-shadow-xl) !important;
    font-family: var(--font-body) !important;
  }

  #tarteaucitron .tarteaucitronH1,
  #tarteaucitron h1,
  #tarteaucitron h2 {
    font-family: var(--font-display) !important;
    font-weight: 800 !important;
    color: var(--m360-text-title) !important;
  }

  #tarteaucitron .tarteaucitronH2 {
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
    color: var(--m360-text-title) !important;
  }

  #tarteaucitron .tarteaucitronTitle button {
    color: var(--m360-text-title) !important;
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
  }

  /* Boutons "Autoriser" / "Interdire" dans le panneau */
  #tarteaucitron .tarteaucitronAllow,
  #tarteaucitron .tarteaucitronDeny {
    border-radius: var(--m360-radius-md) !important;
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
    font-size: 13px !important;
    padding: var(--m360-space-2) var(--m360-space-4) !important;
  }

  #tarteaucitron .tarteaucitronAllow {
    background: var(--m360-blue) !important;
    color: #fff !important;
  }

  #tarteaucitron .tarteaucitronDeny {
    background: var(--m360-bg-neutral) !important;
    color: var(--m360-text-body) !important;
    border: 1px solid var(--m360-border) !important;
  }

  #tarteaucitron .tarteaucitronIsAllowed .tarteaucitronAllow {
    background: var(--m360-navy) !important;
  }

  #tarteaucitron .tarteaucitronIsDenied .tarteaucitronDeny {
    background: var(--m360-pink-dark) !important;
    color: #fff !important;
  }

  /* Responsive mobile */
  @media (max-width: 639px) {
    #tarteaucitronAlertBig {
      flex-direction: column !important;
      align-items: flex-start !important;
      padding: var(--m360-space-4) var(--m360-space-5) !important;
      font-size: 13px !important;
    }

    #tarteaucitronAlertBig #tarteaucitronAlertBigBottom {
      width: 100% !important;
    }
  }
</style>
