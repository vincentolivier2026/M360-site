---
// src/components/CookieBanner.astro
// Gestion des cookies conforme CNIL.
//
// Stratégie :
// - Tarteaucitron gère le consentement en arrière-plan (cookie "tarteaucitron")
// - Son bandeau natif est masqué
// - Une modale centrée M360 le remplace à la première visite
// - Un bouton flottant (bas gauche) permet de rouvrir les préférences
//
// Services déclarés :
// - Pipedrive : consentement REQUIS
// - Plausible : exempté (chargé inconditionnellement dans BaseLayout)
---

<script is:inline src="/tarteaucitron/tarteaucitron.js"></script>

<script is:inline>
  tarteaucitron.init({
    "privacyUrl": "/politique-confidentialite",
    "bodyPosition": "bottom",
    "hashtag": "#tarteaucitron",
    "cookieName": "tarteaucitron",
    "orientation": "bottom",
    "groupServices": false,
    "showDetailsOnClick": true,
    "serviceDefaultState": "wait",
    "showAlertSmall": false,
    "cookieslist": false,
    "closePopup": false,
    "showIcon": false,
    "adblocker": false,
    "DenyAllCta": true,
    "AcceptAllCta": true,
    "highPrivacy": true,
    "handleBrowserDNTRequest": false,
    "removeCredit": false,
    "moreInfoLink": true,
    "useExternalCss": false,
    "useExternalJs": false,
    "readmoreLink": "/politique-confidentialite",
    "mandatory": true,
    "mandatoryCta": true
  });

  tarteaucitron.services.pipedrive = {
    "key": "pipedrive",
    "type": "support",
    "name": "Pipedrive (formulaires)",
    "uri": "https://www.pipedrive.com/fr/privacy",
    "needConsent": true,
    "cookies": [],
    "js": function () {},
    "fallback": function () {}
  };

  (tarteaucitron.job = tarteaucitron.job || []).push('pipedrive');
</script>

<!-- Modale de consentement M360 -->
<div id="cookie-modal" class="cookie-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="cookie-modal-title">
  <div class="cookie-modal-overlay"></div>
  <div class="cookie-modal-panel">

    <div class="cookie-modal-icon" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
        <circle cx="20" cy="20" r="19" stroke="var(--m360-blue)" stroke-width="2"/>
        <circle cx="14" cy="16" r="2.5" fill="var(--m360-navy)"/>
        <circle cx="24" cy="12" r="2" fill="var(--m360-pink-dark)"/>
        <circle cx="27" cy="22" r="2.5" fill="var(--m360-navy)"/>
        <circle cx="17" cy="26" r="2" fill="var(--m360-pink-dark)"/>
        <circle cx="22" cy="28" r="1.5" fill="var(--m360-navy)"/>
      </svg>
    </div>

    <h2 id="cookie-modal-title" class="cookie-modal-title">Vos préférences cookies</h2>
    <p class="cookie-modal-text">
      Ce site utilise des cookies pour vous proposer un formulaire de contact (Pipedrive).
      Plausible Analytics est utilisé sans cookie et ne nécessite pas de consentement.
    </p>
    <a href="/politique-confidentialite" class="cookie-modal-link">Politique de confidentialité →</a>

    <div class="cookie-modal-actions">
      <button id="cookie-accept-all" class="cookie-btn cookie-btn-primary">Tout accepter</button>
      <button id="cookie-deny-all" class="cookie-btn cookie-btn-outline">Tout refuser</button>
      <button id="cookie-customize" class="cookie-btn cookie-btn-ghost">Personnaliser</button>
    </div>

  </div>
</div>

<!-- Bouton flottant pour rouvrir les préférences après choix -->
<button id="cookie-reopen-btn" class="cookie-reopen-btn" aria-label="Gérer mes cookies" hidden>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="3"/>
    <path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/>
  </svg>
  Cookies
</button>

<script>
  // ============================================================
  // Modale cookies M360 — logique d'affichage et d'actions
  // ============================================================

  const modal = document.getElementById('cookie-modal');
  const reopenBtn = document.getElementById('cookie-reopen-btn');

  /** Vérifie si l'utilisateur a déjà fait un choix (cookie tarteaucitron présent) */
  function hasConsented(): boolean {
    return document.cookie.split(';').some(c => c.trim().startsWith('tarteaucitron='));
  }

  function openModal() {
    if (!modal) return;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Afficher le bouton flottant après le premier choix
    if (reopenBtn) reopenBtn.hidden = false;
  }

  // Afficher la modale uniquement si pas encore de choix
  if (!hasConsented()) {
    // Léger délai pour que la page soit visible avant la modale
    setTimeout(openModal, 600);
  } else {
    if (reopenBtn) reopenBtn.hidden = false;
  }

  // Tout accepter
  document.getElementById('cookie-accept-all')?.addEventListener('click', () => {
    const tac = (window as any).tarteaucitron;
    if (tac?.userInterface?.respondAll) tac.userInterface.respondAll(true);
    closeModal();
  });

  // Tout refuser
  document.getElementById('cookie-deny-all')?.addEventListener('click', () => {
    const tac = (window as any).tarteaucitron;
    if (tac?.userInterface?.respondAll) tac.userInterface.respondAll(false);
    closeModal();
  });

  // Personnaliser → ouvre le panneau Tarteaucitron
  document.getElementById('cookie-customize')?.addEventListener('click', () => {
    closeModal();
    const tac = (window as any).tarteaucitron;
    setTimeout(() => {
      if (tac?.userInterface?.openPanel) tac.userInterface.openPanel();
    }, 300);
  });

  // Bouton flottant → rouvre le panneau Tarteaucitron
  reopenBtn?.addEventListener('click', () => {
    const tac = (window as any).tarteaucitron;
    if (tac?.userInterface?.openPanel) tac.userInterface.openPanel();
  });

  // Expose une fonction globale pour le lien "Gérer mes cookies" du footer
  (window as any).openCookiePanel = () => {
    const tac = (window as any).tarteaucitron;
    if (tac?.userInterface?.openPanel) tac.userInterface.openPanel();
  };
</script>

<style is:global>
  /* Neutraliser le root Tarteaucitron — annule le position:fixed bottom:0 injecté en inline */
  #tarteaucitronRoot {
    position: static !important;
    bottom: auto !important;
    left: auto !important;
    right: auto !important;
    top: auto !important;
    width: 0 !important;
    height: 0 !important;
    overflow: visible !important;
  }

  /* Masquer tous les éléments du bandeau natif — toutes variantes */
  #tarteaucitronAlertBig,
  #tarteaucitronAlertSmall,
  #tarteaucitronAlertBigTop,
  #tarteaucitronAlertBigBottom,
  #tarteaucitronDisclaimerAlert,
  #tarteaucitronAlertBig *:not(#tarteaucitron):not(#tarteaucitron *) {
    display: none !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }

  /* S'assurer que le panneau détaillé reste fonctionnel quand ouvert */
  #tarteaucitronRoot #tarteaucitron {
    display: block !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }

  /* Panneau de gestion détaillé — styles M360 */
  #tarteaucitron {
    background: #fff !important;
    border-radius: var(--m360-radius-card) !important;
    box-shadow: var(--m360-shadow-xl) !important;
    font-family: var(--font-body) !important;
  }

  #tarteaucitron .tarteaucitronH1,
  #tarteaucitron h1,
  #tarteaucitron h2 {
    font-family: var(--font-display) !important;
    font-weight: 800 !important;
    color: var(--m360-text-title) !important;
  }

  #tarteaucitron .tarteaucitronH2 {
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
    color: var(--m360-text-title) !important;
  }

  #tarteaucitron .tarteaucitronTitle button {
    color: var(--m360-text-title) !important;
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
  }

  #tarteaucitron .tarteaucitronAllow,
  #tarteaucitron .tarteaucitronDeny {
    border-radius: var(--m360-radius-md) !important;
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
    font-size: 13px !important;
    padding: var(--m360-space-2) var(--m360-space-4) !important;
  }

  #tarteaucitron .tarteaucitronAllow {
    background: var(--m360-blue) !important;
    color: #fff !important;
  }

  #tarteaucitron .tarteaucitronDeny {
    background: var(--m360-bg-neutral) !important;
    color: var(--m360-text-body) !important;
    border: 1px solid var(--m360-border) !important;
  }

  #tarteaucitron .tarteaucitronIsAllowed .tarteaucitronAllow {
    background: var(--m360-navy) !important;
  }

  #tarteaucitron .tarteaucitronIsDenied .tarteaucitronDeny {
    background: var(--m360-pink-dark) !important;
    color: #fff !important;
  }
</style>

<style>
  /* ============================================
     MODALE COOKIES M360
     ============================================ */
  .cookie-modal {
    position: fixed;
    inset: 0;
    z-index: 8000;
    display: flex;
    align-items: center;
    justify-content: center;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
  }

  .cookie-modal.is-open {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.3s ease, visibility 0s linear 0s;
  }

  .cookie-modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(2, 31, 63, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .cookie-modal-panel {
    position: relative;
    width: 92%;
    max-width: 480px;
    background: #fff;
    border-radius: var(--m360-radius-card);
    box-shadow: var(--m360-shadow-modal);
    padding: var(--m360-space-10) var(--m360-space-8);
    text-align: center;
    transform: translateY(16px) scale(0.98);
    transition: transform 0.3s ease-out;
  }

  .cookie-modal.is-open .cookie-modal-panel {
    transform: translateY(0) scale(1);
  }

  .cookie-modal-icon {
    margin-bottom: var(--m360-space-5);
    display: flex;
    justify-content: center;
  }

  .cookie-modal-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(22px, 3vw, 28px);
    letter-spacing: -0.02em;
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-4);
  }

  .cookie-modal-text {
    font-size: 14px;
    line-height: 1.65;
    color: var(--m360-text-body);
    margin: 0 0 var(--m360-space-3);
    max-width: none;
  }

  .cookie-modal-link {
    font-size: 13px;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--m360-blue);
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--m360-space-8);
  }

  .cookie-modal-link:hover {
    text-decoration: underline;
  }

  .cookie-modal-actions {
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-3);
  }

  /* Boutons */
  .cookie-btn {
    width: 100%;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    padding: var(--m360-space-4) var(--m360-space-6);
    border-radius: var(--m360-radius-lg);
    border: none;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
    line-height: 1;
  }

  .cookie-btn-primary {
    background: var(--m360-blue);
    color: #fff;
    box-shadow: var(--m360-shadow-blue);
  }

  .cookie-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--m360-shadow-blue-hover);
  }

  .cookie-btn-outline {
    background: transparent;
    color: var(--m360-text-body);
    border: 1.5px solid var(--m360-border);
  }

  .cookie-btn-outline:hover {
    background: var(--m360-bg-neutral);
  }

  .cookie-btn-ghost {
    background: transparent;
    color: var(--m360-text-caption);
    font-size: 13px;
    font-weight: 500;
    padding: var(--m360-space-2) 0;
  }

  .cookie-btn-ghost:hover {
    color: var(--m360-text-body);
    text-decoration: underline;
  }

  /* Bouton flottant de réouverture */
  .cookie-reopen-btn {
    position: fixed;
    bottom: var(--m360-space-5);
    left: var(--m360-space-5);
    z-index: 7000;
    display: flex;
    align-items: center;
    gap: var(--m360-space-2);
    background: var(--m360-navy);
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 12px;
    padding: var(--m360-space-2) var(--m360-space-4);
    border-radius: var(--m360-radius-pill);
    border: none;
    cursor: pointer;
    box-shadow: var(--m360-shadow-md);
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .cookie-reopen-btn:hover {
    background: var(--m360-blue);
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 639px) {
    .cookie-modal-panel {
      padding: var(--m360-space-8) var(--m360-space-5);
      border-radius: var(--m360-radius-2xl);
    }
  }
</style>
