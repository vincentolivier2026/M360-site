---
// src/components/ContactModal.astro
// Modale "Nous contacter" — pattern conforme RGPD.
//
// Comportement :
// 1. Au chargement de la page : modale fermée, AUCUN script Pipedrive chargé
// 2. Clic sur un bouton [data-open-contact-modal] → ouvre la modale
// 3. Vérification du consentement Tarteaucitron pour Pipedrive :
//    - Consenti → injection du script + affichage du formulaire
//    - Non consenti → message explicatif + bouton pour ouvrir Tarteaucitron
// 4. Le script Pipedrive n'est chargé qu'UNE fois par session, même si la modale
//    est ouverte plusieurs fois.
//
// Singleton : ce composant doit être inclus une seule fois dans BaseLayout.

const PIPEDRIVE_FORM_URL = 'https://webforms.pipedrive.com/f/72vZZGeahXoRGtph1wXUcg8YQo4ckEuXdOhOnLUpvXo7aTOwyPa8VmPb7cgtsmckyD';
---

<div id="contact-modal" class="contact-modal" aria-hidden="true">
  <div class="modal-overlay" data-close-modal></div>

  <div
    class="modal-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="contact-modal-title"
  >
    <header class="modal-header">
      <h2 id="contact-modal-title" class="modal-title">Nous contacter</h2>
      <button
        class="modal-close"
        aria-label="Fermer la modale"
        data-close-modal
      >×</button>
    </header>

    <div class="modal-body">
      {/* Slot du formulaire — Pipedrive injectera le formulaire ici */}
      <div
        id="pipedrive-form-host"
        class="pipedriveWebForms"
        data-pd-webforms={PIPEDRIVE_FORM_URL}
      ></div>

      {/* Message affiché si l'utilisateur n'a pas consenti aux cookies Pipedrive */}
      <div id="pipedrive-consent-block" class="consent-block" hidden>
        <div class="consent-icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a10 10 0 1 0 10 10A10.011 10.011 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8.009 8.009 0 0 1-8 8z"/>
            <path d="M12 17.5a1 1 0 1 0 1 1 1 1 0 0 0-1-1zM12 6a2.5 2.5 0 0 0-2.5 2.5.5.5 0 0 0 1 0 1.5 1.5 0 0 1 3 0c0 .82-.36 1.16-1.06 1.69A2.628 2.628 0 0 0 11 12.5v1a.5.5 0 0 0 1 0v-1a1.683 1.683 0 0 1 .92-1.51c.83-.62 1.58-1.18 1.58-2.49A2.5 2.5 0 0 0 12 6z"/>
          </svg>
        </div>
        <h3 class="consent-title">Formulaire bloqué par vos préférences cookies</h3>
        <p class="consent-text">
          Pour afficher ce formulaire de contact, vous devez autoriser le service
          <strong>Pipedrive</strong>. Aucune donnée n'est transmise tant que vous
          n'avez pas donné votre consentement.
        </p>
        <button class="consent-btn" id="open-cookies-from-modal">
          Gérer mes préférences cookies
        </button>
      </div>

      {/* État de chargement */}
      <div id="pipedrive-loading" class="loading-block" hidden>
        <div class="loading-spinner" aria-hidden="true"></div>
        <p>Chargement du formulaire…</p>
      </div>
    </div>
  </div>
</div>

<style>
  /* ============================================
     MODALE — fixed plein écran, fond navy translucide
     ============================================ */
  .contact-modal {
    position: fixed;
    inset: 0;
    z-index: 1500;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0s linear 0.25s;
  }

  .contact-modal.is-open {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.25s ease, visibility 0s linear 0s;
  }

  .modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(2, 31, 63, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .modal-panel {
    position: relative;
    width: 92%;
    max-width: 640px;
    max-height: 90vh;
    max-height: 90dvh;
    margin: 5vh auto;
    background: #fff;
    border-radius: var(--m360-radius-card);
    box-shadow: var(--m360-shadow-modal);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(20px);
    transition: transform 0.3s ease-out;
  }

  .contact-modal.is-open .modal-panel {
    transform: translateY(0);
  }

  /* ============================================
     HEADER DE MODALE
     ============================================ */
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--m360-space-6) var(--m360-space-8);
    border-bottom: 1px solid var(--m360-border);
    flex-shrink: 0;
  }

  .modal-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 24px;
    color: var(--m360-text-title);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .modal-close {
    width: 36px;
    height: 36px;
    background: var(--m360-bg-neutral);
    border: none;
    border-radius: 50%;
    font-size: 24px;
    line-height: 1;
    color: var(--m360-text-title);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s ease;
  }

  .modal-close:hover {
    background: var(--m360-border);
  }

  /* ============================================
     CORPS DE MODALE
     ============================================ */
  .modal-body {
    padding: var(--m360-space-6) var(--m360-space-8) var(--m360-space-8);
    overflow-y: auto;
    flex: 1 1 auto;
    min-height: 200px;
  }

  /* ============================================
     BLOC CONSENTEMENT — affiché si Pipedrive non autorisé
     ============================================ */
  .consent-block {
    text-align: center;
    padding: var(--m360-space-8) var(--m360-space-4);
  }

  .consent-icon {
    color: var(--m360-blue);
    margin-bottom: var(--m360-space-5);
    display: flex;
    justify-content: center;
  }

  .consent-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 19px;
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-4);
  }

  .consent-text {
    font-size: 15px;
    line-height: 1.6;
    color: var(--m360-text-body);
    margin: 0 0 var(--m360-space-6);
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
  }

  .consent-text strong {
    color: var(--m360-text-title);
    font-weight: 700;
  }

  .consent-btn {
    background: var(--m360-blue);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    padding: var(--m360-space-4) var(--m360-space-7);
    border-radius: var(--m360-radius-lg);
    border: none;
    cursor: pointer;
    box-shadow: var(--m360-shadow-blue);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .consent-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--m360-shadow-blue-hover);
  }

  /* ============================================
     ÉTAT DE CHARGEMENT
     ============================================ */
  .loading-block {
    text-align: center;
    padding: var(--m360-space-12) var(--m360-space-4);
    color: var(--m360-text-caption);
  }

  .loading-spinner {
    width: 32px;
    height: 32px;
    margin: 0 auto var(--m360-space-4);
    border: 3px solid var(--m360-border);
    border-top-color: var(--m360-blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 639px) {
    .modal-panel {
      width: 100%;
      margin: 0;
      max-height: 100vh;
      max-height: 100dvh;
      border-radius: 0;
    }
    .modal-header {
      padding: var(--m360-space-5) var(--m360-space-5);
    }
    .modal-body {
      padding: var(--m360-space-5);
    }
    .modal-title {
      font-size: 20px;
    }
  }
</style>

<script>
  // ============================================================
  // ContactModal — gestion d'ouverture/fermeture + lazy loading Pipedrive
  // ============================================================

  const modal = document.getElementById('contact-modal');
  const formHost = document.getElementById('pipedrive-form-host');
  const consentBlock = document.getElementById('pipedrive-consent-block');
  const loadingBlock = document.getElementById('pipedrive-loading');
  const openCookiesBtn = document.getElementById('open-cookies-from-modal');

  // État : avons-nous déjà injecté le script Pipedrive ?
  let pipedriveLoaded = false;

  /**
   * Vérifie le consentement utilisateur pour Pipedrive via Tarteaucitron.
   * Retourne true si consenti, false sinon.
   */
  function isPipedriveConsented(): boolean {
    // Tarteaucitron expose son état via window.tarteaucitron.state
    const tac = (window as any).tarteaucitron;
    if (!tac || !tac.state) return false;
    return tac.state['pipedrive'] === true;
  }

  /**
   * Injecte le script Pipedrive dans la modale.
   * Une seule fois par session.
   */
  function loadPipedriveScript() {
    if (pipedriveLoaded) return;
    if (!formHost) return;

    pipedriveLoaded = true;
    if (loadingBlock) loadingBlock.hidden = false;

    const script = document.createElement('script');
    script.src = 'https://webforms.pipedrive.com/f/loader';
    script.async = true;
    script.onload = () => {
      if (loadingBlock) loadingBlock.hidden = true;
    };
    script.onerror = () => {
      if (loadingBlock) {
        loadingBlock.innerHTML = '<p style="color:var(--m360-text-caption)">Erreur de chargement du formulaire. Réessayez ou contactez-nous à <a href="mailto:vincent@metiers360.com">vincent@metiers360.com</a></p>';
      }
      pipedriveLoaded = false;
    };

    // On injecte le script juste après le host pour que Pipedrive trouve le sélecteur
    formHost.appendChild(script);
  }

  /**
   * Met à jour l'affichage de la modale en fonction du consentement.
   */
  function updateModalState() {
    if (!formHost || !consentBlock) return;

    if (isPipedriveConsented()) {
      consentBlock.hidden = true;
      formHost.style.display = 'block';
      loadPipedriveScript();
    } else {
      consentBlock.hidden = false;
      formHost.style.display = 'none';
      if (loadingBlock) loadingBlock.hidden = true;
    }
  }

  /**
   * Ouvre la modale.
   */
  function openContactModal() {
    if (!modal) return;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    updateModalState();
  }

  /**
   * Ferme la modale.
   */
  function closeContactModal() {
    if (!modal) return;
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // ============================================================
  // Branchement des événements
  // ============================================================

  // Boutons d'ouverture — TOUS les [data-open-contact-modal] de la page
  document.querySelectorAll('[data-open-contact-modal]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      openContactModal();
    });
  });

  // Boutons de fermeture (overlay + croix)
  modal?.querySelectorAll('[data-close-modal]').forEach(btn => {
    btn.addEventListener('click', closeContactModal);
  });

  // Bouton "Gérer mes préférences cookies" dans le bloc consentement
  openCookiesBtn?.addEventListener('click', () => {
    closeContactModal();
    // Ouvre le panneau Tarteaucitron
    const tac = (window as any).tarteaucitron;
    if (tac && tac.userInterface && tac.userInterface.openPanel) {
      tac.userInterface.openPanel();
    }
  });

  // Fermeture clavier (Escape)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('is-open')) {
      closeContactModal();
    }
  });

  // ============================================================
  // Réaction au changement de consentement Tarteaucitron
  // Si l'utilisateur consent à Pipedrive ALORS QUE la modale est ouverte,
  // on charge automatiquement le formulaire.
  // ============================================================
  document.addEventListener('tac.before_responses', () => {
    if (modal?.classList.contains('is-open')) {
      updateModalState();
    }
  });
</script>
