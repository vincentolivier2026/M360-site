---
// src/components/ContactModal.astro
// Modale "Nous contacter" — V2 fix : création dynamique de la div Pipedrive.
//
// Pattern :
// 1. Au chargement de la page : modale fermée, AUCUN <div class="pipedriveWebForms"> dans le DOM
// 2. Clic "Nous contacter" → ouverture de la modale
// 3. À la première ouverture :
//    - Création dynamique de <div class="pipedriveWebForms" data-pd-webforms="...">
//    - Injection du <script> Pipedrive APRÈS la div
//    - Pipedrive scanne, trouve la div fraîchement créée, injecte le formulaire
//
// Cette approche évite le problème où Pipedrive ne trouve pas une div cachée
// au chargement initial.

const PIPEDRIVE_FORM_URL = 'https://webforms.pipedrive.com/f/72vZZGeahXoRGtph1wXUcg8YQo4ckEuXdOhOnLUpvXo7aTOwyPa8VmPb7cgtsmckyD';
---

<div id="contact-modal" class="contact-modal" aria-hidden="true">
  <div class="modal-overlay" data-close-modal></div>

  <div
    class="modal-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="contact-modal-title"
  >
    <header class="modal-header">
      <h2 id="contact-modal-title" class="modal-title">Nous contacter</h2>
      <button
        class="modal-close"
        aria-label="Fermer la modale"
        data-close-modal
      >×</button>
    </header>

    <div class="modal-body">
      {/* Container vide — la div pipedriveWebForms sera injectée ici par JS
          à la première ouverture de la modale */}
      <div id="pipedrive-container"></div>

      <div id="pipedrive-loading" class="loading-block">
        <div class="loading-spinner" aria-hidden="true"></div>
        <p>Chargement du formulaire…</p>
      </div>

      {/* Fallback affiché si le formulaire n'a pas chargé après 8 secondes */}
      <div id="pipedrive-fallback" class="fallback-block" hidden>
        <p>
          Le formulaire de contact ne s'est pas chargé. Vérifiez que votre
          bloqueur de publicités n'est pas actif, ou contactez-nous directement
          par e-mail à
          <a href="mailto:vincent@metiers360.com">vincent@metiers360.com</a>.
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .contact-modal {
    position: fixed;
    inset: 0;
    z-index: 1500;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0s linear 0.25s;
  }

  .contact-modal.is-open {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.25s ease, visibility 0s linear 0s;
  }

  .modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(2, 31, 63, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .modal-panel {
    position: relative;
    width: 92%;
    max-width: 640px;
    max-height: 90vh;
    max-height: 90dvh;
    margin: 5vh auto;
    background: #fff;
    border-radius: var(--m360-radius-card);
    box-shadow: var(--m360-shadow-modal);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(20px);
    transition: transform 0.3s ease-out;
  }

  .contact-modal.is-open .modal-panel {
    transform: translateY(0);
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--m360-space-6) var(--m360-space-8);
    border-bottom: 1px solid var(--m360-border);
    flex-shrink: 0;
  }

  .modal-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 24px;
    color: var(--m360-text-title);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .modal-close {
    width: 36px;
    height: 36px;
    background: var(--m360-bg-neutral);
    border: none;
    border-radius: 50%;
    font-size: 24px;
    line-height: 1;
    color: var(--m360-text-title);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s ease;
  }

  .modal-close:hover {
    background: var(--m360-border);
  }

  .modal-body {
    padding: var(--m360-space-6) var(--m360-space-8) var(--m360-space-8);
    overflow-y: auto;
    flex: 1 1 auto;
    min-height: 200px;
    position: relative;
  }

  .loading-block {
    text-align: center;
    padding: var(--m360-space-12) var(--m360-space-4);
    color: var(--m360-text-caption);
  }

  .loading-block[hidden] {
    display: none;
  }

  .loading-spinner {
    width: 32px;
    height: 32px;
    margin: 0 auto var(--m360-space-4);
    border: 3px solid var(--m360-border);
    border-top-color: var(--m360-blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .fallback-block {
    padding: var(--m360-space-8) var(--m360-space-4);
    text-align: center;
    color: var(--m360-text-body);
    font-size: 15px;
    line-height: 1.6;
  }

  .fallback-block[hidden] {
    display: none;
  }

  .fallback-block a {
    color: var(--m360-blue);
    font-weight: 700;
  }

  @media (max-width: 639px) {
    .modal-panel {
      width: 100%;
      margin: 0;
      max-height: 100vh;
      max-height: 100dvh;
      border-radius: 0;
    }
    .modal-header {
      padding: var(--m360-space-5) var(--m360-space-5);
    }
    .modal-body {
      padding: var(--m360-space-5);
    }
    .modal-title {
      font-size: 20px;
    }
  }
</style>

<script define:vars={{ PIPEDRIVE_FORM_URL }}>
  // ============================================================
  // ContactModal — V2 fix : injection dynamique de la div + script
  // ============================================================

  const modal = document.getElementById('contact-modal');
  const container = document.getElementById('pipedrive-container');
  const loadingBlock = document.getElementById('pipedrive-loading');
  const fallbackBlock = document.getElementById('pipedrive-fallback');

  let pipedriveInjected = false;
  let loadTimeoutId = null;

  /**
   * Injecte la div pipedriveWebForms ET le script loader.
   * Pipedrive trouvera la div fraîchement créée et injectera le formulaire dedans.
   */
  function injectPipedrive() {
    if (pipedriveInjected) return;
    if (!container) return;

    pipedriveInjected = true;
    console.info('[M360] Injection du formulaire Pipedrive…');

    // 1) Création de la div cible
    const pdDiv = document.createElement('div');
    pdDiv.className = 'pipedriveWebForms';
    pdDiv.setAttribute('data-pd-webforms', PIPEDRIVE_FORM_URL);

    // 2) Création du script
    const script = document.createElement('script');
    script.src = 'https://webforms.pipedrive.com/f/loader';
    script.async = true;

    script.onload = () => {
      console.info('[M360] Script Pipedrive chargé.');
      // Le formulaire peut prendre encore 1-2s pour s'afficher après le script
      setTimeout(() => {
        if (loadingBlock) loadingBlock.hidden = true;
      }, 1500);
    };

    script.onerror = (e) => {
      console.error('[M360] Erreur de chargement du script Pipedrive :', e);
      showFallback();
    };

    // 3) Ordre d'insertion : div d'abord, script après — comme dans le snippet officiel
    container.appendChild(pdDiv);
    container.appendChild(script);

    // 4) Timeout de sécurité : si après 8 secondes le formulaire n'est pas visible, on bascule en fallback
    loadTimeoutId = window.setTimeout(() => {
      const hasFormContent = pdDiv && pdDiv.children.length > 0;
      if (!hasFormContent) {
        console.warn('[M360] Formulaire Pipedrive non visible après 8s — fallback.');
        showFallback();
      }
    }, 8000);
  }

  function showFallback() {
    if (loadingBlock) loadingBlock.hidden = true;
    if (fallbackBlock) fallbackBlock.hidden = false;
    if (loadTimeoutId) {
      clearTimeout(loadTimeoutId);
      loadTimeoutId = null;
    }
  }

  function openContactModal() {
    if (!modal) return;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    // Charger le formulaire à la première ouverture
    if (!pipedriveInjected) {
      // Petit délai pour laisser la modale finir son animation d'ouverture
      // (Pipedrive a besoin que la div cible soit dans le DOM visible)
      setTimeout(injectPipedrive, 100);
    }
  }

  function closeContactModal() {
    if (!modal) return;
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Branchement des événements
  document.querySelectorAll('[data-open-contact-modal]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      openContactModal();
    });
  });

  modal?.querySelectorAll('[data-close-modal]').forEach(btn => {
    btn.addEventListener('click', closeContactModal);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('is-open')) {
      closeContactModal();
    }
  });
</script>
