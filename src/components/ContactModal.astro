---
// src/components/ContactModal.astro
// Modale "Nous contacter" — VERSION PRÉ-PROD PRIVÉE (sans Tarteaucitron).
//
// IMPORTANT : cette version charge Pipedrive directement, sans consentement.
// À REMETTRE EN PLACE TARTEAUCITRON AVANT TOUT PASSAGE EN PRODUCTION PUBLIQUE
// (cohérence avec la politique de confidentialité V2 qui annonce le consentement).
//
// Comportement actuel :
// 1. Au chargement de la page : modale fermée, AUCUN script Pipedrive chargé
// 2. Clic sur un bouton [data-open-contact-modal] → ouverture de la modale
// 3. À la première ouverture : injection du script Pipedrive dans la modale
// 4. Le script Pipedrive n'est chargé qu'UNE fois par session
//
// Singleton : à inclure une seule fois dans BaseLayout.

const PIPEDRIVE_FORM_URL = 'https://webforms.pipedrive.com/f/72vZZGeahXoRGtph1wXUcg8YQo4ckEuXdOhOnLUpvXo7aTOwyPa8VmPb7cgtsmckyD';
---

<div id="contact-modal" class="contact-modal" aria-hidden="true">
  <div class="modal-overlay" data-close-modal></div>

  <div
    class="modal-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="contact-modal-title"
  >
    <header class="modal-header">
      <h2 id="contact-modal-title" class="modal-title">Nous contacter</h2>
      <button
        class="modal-close"
        aria-label="Fermer la modale"
        data-close-modal
      >×</button>
    </header>

    <div class="modal-body">
      <div
        id="pipedrive-form-host"
        class="pipedriveWebForms"
        data-pd-webforms={PIPEDRIVE_FORM_URL}
      ></div>

      <div id="pipedrive-loading" class="loading-block">
        <div class="loading-spinner" aria-hidden="true"></div>
        <p>Chargement du formulaire…</p>
      </div>
    </div>
  </div>
</div>

<style>
  /* ============================================
     MODALE — fixed plein écran
     ============================================ */
  .contact-modal {
    position: fixed;
    inset: 0;
    z-index: 1500;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0s linear 0.25s;
  }

  .contact-modal.is-open {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.25s ease, visibility 0s linear 0s;
  }

  .modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(2, 31, 63, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .modal-panel {
    position: relative;
    width: 92%;
    max-width: 640px;
    max-height: 90vh;
    max-height: 90dvh;
    margin: 5vh auto;
    background: #fff;
    border-radius: var(--m360-radius-card);
    box-shadow: var(--m360-shadow-modal);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(20px);
    transition: transform 0.3s ease-out;
  }

  .contact-modal.is-open .modal-panel {
    transform: translateY(0);
  }

  /* ============================================
     HEADER DE MODALE
     ============================================ */
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--m360-space-6) var(--m360-space-8);
    border-bottom: 1px solid var(--m360-border);
    flex-shrink: 0;
  }

  .modal-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 24px;
    color: var(--m360-text-title);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .modal-close {
    width: 36px;
    height: 36px;
    background: var(--m360-bg-neutral);
    border: none;
    border-radius: 50%;
    font-size: 24px;
    line-height: 1;
    color: var(--m360-text-title);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s ease;
  }

  .modal-close:hover {
    background: var(--m360-border);
  }

  /* ============================================
     CORPS DE MODALE
     ============================================ */
  .modal-body {
    padding: var(--m360-space-6) var(--m360-space-8) var(--m360-space-8);
    overflow-y: auto;
    flex: 1 1 auto;
    min-height: 200px;
    position: relative;
  }

  /* Le formulaire Pipedrive est masqué tant que le script n'est pas chargé */
  .pipedriveWebForms:empty {
    min-height: 0;
  }

  /* ============================================
     ÉTAT DE CHARGEMENT
     ============================================ */
  .loading-block {
    text-align: center;
    padding: var(--m360-space-12) var(--m360-space-4);
    color: var(--m360-text-caption);
  }

  .loading-block[hidden] {
    display: none;
  }

  .loading-spinner {
    width: 32px;
    height: 32px;
    margin: 0 auto var(--m360-space-4);
    border: 3px solid var(--m360-border);
    border-top-color: var(--m360-blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 639px) {
    .modal-panel {
      width: 100%;
      margin: 0;
      max-height: 100vh;
      max-height: 100dvh;
      border-radius: 0;
    }
    .modal-header {
      padding: var(--m360-space-5) var(--m360-space-5);
    }
    .modal-body {
      padding: var(--m360-space-5);
    }
    .modal-title {
      font-size: 20px;
    }
  }
</style>

<script>
  // ============================================================
  // ContactModal — version simplifiée (sans Tarteaucitron)
  // ============================================================

  const modal = document.getElementById('contact-modal');
  const formHost = document.getElementById('pipedrive-form-host');
  const loadingBlock = document.getElementById('pipedrive-loading');

  let pipedriveLoaded = false;

  /**
   * Injecte le script Pipedrive — une seule fois par session.
   */
  function loadPipedriveScript() {
    if (pipedriveLoaded) return;
    if (!formHost) return;

    pipedriveLoaded = true;

    const script = document.createElement('script');
    script.src = 'https://webforms.pipedrive.com/f/loader';
    script.async = true;
    script.onload = () => {
      // Le formulaire injecte son DOM dans formHost, on peut cacher le spinner
      // mais on laisse 500ms à Pipedrive pour terminer l'injection
      setTimeout(() => {
        if (loadingBlock) loadingBlock.hidden = true;
      }, 500);
    };
    script.onerror = () => {
      if (loadingBlock) {
        loadingBlock.innerHTML = '<p style="color:var(--m360-text-caption)">Erreur de chargement du formulaire. Réessayez ou contactez-nous à <a href="mailto:vincent@metiers360.com" style="color:var(--m360-blue)">vincent@metiers360.com</a></p>';
      }
      pipedriveLoaded = false;
    };

    formHost.appendChild(script);
  }

  /**
   * Ouvre la modale et charge le formulaire si pas déjà fait.
   */
  function openContactModal() {
    if (!modal) return;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    // Charger le formulaire Pipedrive si pas déjà chargé
    if (!pipedriveLoaded) {
      loadPipedriveScript();
    }
  }

  /**
   * Ferme la modale.
   */
  function closeContactModal() {
    if (!modal) return;
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // ============================================================
  // Branchement des événements
  // ============================================================

  // Tous les boutons [data-open-contact-modal] de la page
  document.querySelectorAll('[data-open-contact-modal]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      openContactModal();
    });
  });

  // Boutons de fermeture (overlay + croix)
  modal?.querySelectorAll('[data-close-modal]').forEach(btn => {
    btn.addEventListener('click', closeContactModal);
  });

  // Fermeture clavier
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('is-open')) {
      closeContactModal();
    }
  });
</script>
