---
// src/components/AccessCard.astro
// Carte d'accès rapide — utilisée sur la page Espace client.
// Source : Design System V0.12 — composant .access-card
//
// Usage :
// <AccessCard
//   href="https://..."
//   icon="📘"
//   title="Guide premier pas"
//   desc="Démarrer avec Métiers 360 — installation, animation, premières séances."
//   arrow="Consulter"
//   tone="pink"
//   external={true}
//   fresh="Nouveau"
// />

interface Props {
  /** URL de destination (interne ou externe) */
  href: string;
  /** Caractère/emoji ou symbole pour l'icône */
  icon: string;
  /** Titre principal de la carte */
  title: string;
  /** Description courte */
  desc: string;
  /** Texte du bouton fléché en bas (ex. "Explorer", "Consulter", "Obtenir de l'aide") */
  arrow: string;
  /** Variante visuelle de l'icône */
  tone?: 'blue' | 'pink';
  /** Si vrai, ouvre dans un nouvel onglet avec rel sécurisé */
  external?: boolean;
  /** Badge "fresh" en haut-droite (ex. "Nouveau", "5 nouveautés"). Vide = pas de badge */
  fresh?: string;
}

const {
  href,
  icon,
  title,
  desc,
  arrow,
  tone = 'blue',
  external = false,
  fresh,
} = Astro.props;

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<a href={href} class={`access-card ${tone === 'pink' ? 'pink' : ''}`} {...externalAttrs}>
  <div class="access-card-icon">{icon}</div>
  {fresh && <span class="access-card-fresh">{fresh}</span>}
  <div class="access-card-title">{title}</div>
  <div class="access-card-desc">{desc}</div>
  <div class="access-card-arrow">
    {arrow}
    {external && <span class="access-card-external-ico" aria-label="(ouvre dans un nouvel onglet)">↗</span>}
  </div>
</a>

<style>
  .access-card {
    background: #fff;
    border: 1px solid var(--m360-border);
    border-radius: var(--m360-radius-3xl);
    padding: var(--m360-space-7) var(--m360-space-7) var(--m360-space-6);
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-3);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    min-height: 180px;
  }

  .access-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 32px rgba(2, 31, 63, 0.1);
    border-color: rgba(0, 128, 244, 0.25);
    text-decoration: none;
  }

  .access-card-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--m360-radius-xl);
    background: var(--m360-blue-bg);
    color: var(--m360-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .access-card.pink .access-card-icon {
    background: var(--m360-pink-bg);
    color: var(--m360-pink-dark);
  }

  .access-card-fresh {
    position: absolute;
    top: var(--m360-space-4);
    right: var(--m360-space-4);
    background: var(--m360-pink-bg);
    color: var(--m360-pink-dark);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--m360-space-1) var(--m360-space-3);
    border-radius: var(--m360-radius-xl);
  }

  .access-card-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
    color: var(--m360-text-title);
    line-height: 1.3;
  }

  .access-card-desc {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.55;
    color: var(--m360-text-body);
    margin: 0;
    max-width: none;
  }

  .access-card-arrow {
    margin-top: auto;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 13px;
    color: var(--m360-blue);
    display: flex;
    align-items: center;
    gap: var(--m360-space-1);
  }

  .access-card-arrow::after {
    content: '→';
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .access-card:hover .access-card-arrow::after {
    transform: translateX(4px);
  }

  .access-card-external-ico {
    margin-left: var(--m360-space-1);
    opacity: 0.5;
    font-size: 11px;
  }
</style>
