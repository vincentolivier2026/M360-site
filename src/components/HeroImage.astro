---
// src/components/HeroImage.astro
// Hero immersif "image immersion" — variante simplifiée du Hero système.
// Photo en background full-bleed, overlay navy translucide, signature centrée, CTAs.
//
// Pourquoi pas l'iframe YouTube : cause des bugs de pointer-events qui bloquaient
// les clics sur la nav et le menu burger mobile. La photo statique élimine le problème
// et règle aussi le RGPD (pas de cookies tiers).
//
// Usage :
// <HeroImage
//   image="/images/photohero.jpg"
//   imageAlt="Atelier immersion VR Métiers 360"
//   signature="L'expérience<br>change tout."
//   ctaPrimary={{ label: '...', href: '/...' }}
//   ctaSecondary={{ label: '...', href: '/...' }}
// />

import Button from './Button.astro';

interface Props {
  /** URL de l'image (chemin /images/... dans public/) */
  image: string;
  /** Texte alternatif de l'image — vide si l'image est purement décorative */
  imageAlt?: string;
  /** Titre principal — peut contenir un <br> */
  signature: string;
  /** CTA primaire */
  ctaPrimary: { label: string; href: string };
  /** CTA secondaire */
  ctaSecondary: { label: string; href: string };
  /** Position du focus de l'image (équivalent de object-position) — défaut "center" */
  imagePosition?: string;
}

const {
  image,
  imageAlt = '',
  signature,
  ctaPrimary,
  ctaSecondary,
  imagePosition = 'center',
} = Astro.props;
---

<section class="hero" aria-label="Présentation de Métiers 360">
  <div class="hero-image-wrapper">
    <img
      src={image}
      alt={imageAlt}
      class="hero-image"
      style={`object-position: ${imagePosition};`}
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <h1 class="hero-signature" set:html={signature}></h1>
    <div class="hero-ctas">
      <Button variant="primary" href={ctaPrimary.href} arrow>
        {ctaPrimary.label}
      </Button>
      <Button variant="secondary" href={ctaSecondary.href} arrow>
        {ctaSecondary.label}
      </Button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 640px;
    max-height: 820px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    overflow: hidden;
    background: var(--m360-navy);
    /* CRITIQUE : isolation du contexte d'empilement pour que les enfants
       restent confinés et ne débordent pas par-dessus le Header sticky */
    isolation: isolate;
  }

  .hero-image-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* object-position est défini en inline via la prop imagePosition */
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(2, 31, 63, 0.45) 0%,
      rgba(2, 31, 63, 0.65) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 920px;
    padding: 0 var(--m360-space-8);
    text-align: center;
  }

  .hero-signature {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(48px, 8vw, 96px);
    line-height: 1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 var(--m360-space-12);
    text-shadow:
      0 2px 24px rgba(2, 31, 63, 0.5),
      0 1px 4px rgba(2, 31, 63, 0.3);
  }

  .hero-ctas {
    display: flex;
    gap: var(--m360-space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 967px) {
    .hero {
      height: 88vh;
      min-height: 560px;
    }
  }

  @media (max-width: 639px) {
    .hero-content {
      padding: 0 var(--m360-space-5);
    }
  }
</style>
