---
// src/components/StatsBlock.astro
// Bloc "3 chiffres clés" réutilisable — home, à propos, références.
// Liseret rose en haut de section, bulles colorées qui alternent bleu/rose.
//
// Usage :
// <StatsBlock stats={[
//   { number: '300', label: 'métiers présents au catalogue', tone: 'blue' },
//   { number: '2 200', label: 'structures équipées depuis 2018', tone: 'pink' },
//   { number: '1,7M', label: "immersions réalisées", tone: 'blue' },
// ]} />

interface Stat {
  /** Valeur affichée — peut contenir un séparateur de milliers (espace insécable) */
  number: string;
  /** Libellé sous la valeur */
  label: string;
  /** Couleur de fond et de chiffre */
  tone: 'blue' | 'pink';
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="stats" aria-label="Chiffres clés Métiers 360">
  <div class="stats-inner">
    {stats.map(stat => (
      <div class={`stat stat-${stat.tone}`}>
        <div class={`stat-number ${stat.tone}`}>{stat.number}</div>
        <div class="stat-label">{stat.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .stats {
    position: relative;
    padding: var(--m360-space-16) var(--m360-space-8) var(--m360-space-14);
    background: #fff;
  }

  /* Liseret rose en haut de section */
  .stats::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background: var(--m360-pink);
    border-radius: 2px;
  }

  .stats-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--m360-space-10);
    text-align: center;
  }

  .stat {
    padding: var(--m360-space-12) var(--m360-space-6);
    border-radius: var(--m360-radius-card);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    border: 1px solid transparent;
  }

  .stat-blue {
    background: var(--m360-blue-bg);
    border-color: rgba(0, 128, 244, 0.15);
  }

  .stat-pink {
    background: var(--m360-pink-bg);
    border-color: rgba(214, 128, 249, 0.2);
  }

  .stat:hover {
    transform: translateY(-4px);
    box-shadow: var(--m360-shadow-md);
  }

  .stat-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(56px, 6vw, 88px);
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: var(--m360-space-5);
  }

  .stat-number.blue {
    color: var(--m360-blue);
  }

  .stat-number.pink {
    color: var(--m360-pink-dark);
  }

  .stat-label {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 19px;
    color: var(--m360-text-title);
    line-height: 1.3;
  }

  @media (max-width: 967px) {
    .stats-inner {
      gap: var(--m360-space-6);
    }
  }

  @media (max-width: 639px) {
    .stats {
      padding: var(--m360-space-12) var(--m360-space-5) var(--m360-space-10);
    }
    .stats-inner {
      grid-template-columns: 1fr;
      gap: var(--m360-space-5);
    }
    .stat {
      padding: var(--m360-space-9) var(--m360-space-5);
    }
  }
</style>
