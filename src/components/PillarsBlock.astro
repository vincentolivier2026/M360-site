---
// src/components/PillarsBlock.astro
// Bloc "Notre proposition" — 3 piliers en escalier visuel.
// Décalage vertical : pilier 2 plus bas que 1 et 3 (effet escalier).
//
// Source : Metiers360-Landing-Accompagnement-G3.html, bloc 2.

import EyebrowPill from './EyebrowPill.astro';

interface Pillar {
  /** Numéro affiché (01, 02, 03) */
  num: string;
  /** Titre du pilier */
  title: string;
  /** Description */
  text: string;
}

interface Props {
  eyebrow: string;
  title: string;
  pillars: Pillar[];
}

const { eyebrow, title, pillars } = Astro.props;
---

<section class="pillars-section">
  <div class="pillars-inner">
    <header class="pillars-header">
      <EyebrowPill tone="blue">{eyebrow}</EyebrowPill>
      <h2 class="pillars-title">{title}</h2>
    </header>

    <div class="pillars-grid">
      {pillars.map((pillar, i) => (
        <article class="pillar" data-pillar-index={i + 1}>
          <span class="pillar-num">{pillar.num}</span>
          <h3 class="pillar-title">{pillar.title}</h3>
          <p class="pillar-text">{pillar.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars-section {
    padding: var(--m360-space-16) var(--m360-space-8);
    background: var(--m360-bg-neutral);
  }

  .pillars-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .pillars-header {
    text-align: center;
    margin-bottom: var(--m360-space-14);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .pillars-header :global(.eyebrow) {
    margin-bottom: var(--m360-space-5);
  }

  .pillars-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(28px, 3.5vw, 42px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--m360-text-title);
    margin: 0;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--m360-space-8);
    align-items: start;
  }

  /* Décalage vertical "escalier" — distinctif de la marque M360 */
  .pillar[data-pillar-index="1"] { transform: translateY(0); }
  .pillar[data-pillar-index="2"] { transform: translateY(60px); }
  .pillar[data-pillar-index="3"] { transform: translateY(20px); }

  .pillar {
    background: #fff;
    padding: var(--m360-space-9) var(--m360-space-7);
    border-radius: var(--m360-radius-card);
    box-shadow: var(--m360-shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .pillar:hover {
    box-shadow: var(--m360-shadow-lg);
  }

  .pillar[data-pillar-index="1"]:hover { transform: translateY(-8px); }
  .pillar[data-pillar-index="2"]:hover { transform: translateY(52px); }
  .pillar[data-pillar-index="3"]:hover { transform: translateY(12px); }

  .pillar-num {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 48px;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: var(--m360-space-5);
  }

  /* Couleurs des numéros : bleu / rose / bleu */
  .pillar[data-pillar-index="1"] .pillar-num { color: var(--m360-blue); }
  .pillar[data-pillar-index="2"] .pillar-num { color: var(--m360-pink-dark); }
  .pillar[data-pillar-index="3"] .pillar-num { color: var(--m360-blue); }

  .pillar-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    line-height: 1.3;
    color: var(--m360-text-title);
    margin: 0 0 var(--m360-space-4);
  }

  .pillar-text {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--m360-text-body);
    margin: 0;
    max-width: none;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 967px) {
    .pillars-grid {
      grid-template-columns: 1fr;
      gap: var(--m360-space-6);
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
    }
    /* Sur mobile, on supprime l'effet escalier (peu lisible) */
    .pillar[data-pillar-index="1"],
    .pillar[data-pillar-index="2"],
    .pillar[data-pillar-index="3"] {
      transform: translateY(0);
    }
    .pillar[data-pillar-index="1"]:hover,
    .pillar[data-pillar-index="2"]:hover,
    .pillar[data-pillar-index="3"]:hover {
      transform: translateY(-4px);
    }
  }

  @media (max-width: 639px) {
    .pillars-section {
      padding: var(--m360-space-12) var(--m360-space-5);
    }
  }
</style>
