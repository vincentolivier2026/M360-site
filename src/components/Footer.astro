---
// src/components/Footer.astro
// Footer 4 colonnes navy, source : Sitemap V3 §8.2 + DS V0.12 §08.
// Identité · Métiers 360 · Découvrir · Contacter
// Sous-footer : copyright à gauche, liens légaux à droite.
---

<footer class="site-footer">
  <div class="footer-top">

    {/* Colonne 1 — Identité */}
    <div class="footer-col footer-brand">
      <a href="/" class="footer-logo-link" aria-label="Métiers 360 — accueil">
        <img
          src="/logos/m360-logo.png"
          alt="Métiers 360"
          width="56"
          height="56"
          class="footer-logo"
        />
      </a>
      <p class="footer-signature">L'expérience change tout.</p>
      <div class="footer-socials">
        <a
          href="https://www.linkedin.com/company/metiers360"
          class="social-link"
          aria-label="LinkedIn Métiers 360"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.339 18.337v-8.65H5.667v8.65h2.672zM7.003 8.521a1.548 1.548 0 1 0 0-3.096 1.548 1.548 0 0 0 0 3.096zm11.335 9.816v-4.74c0-2.394-1.281-3.508-2.99-3.508-1.378 0-1.99.749-2.336 1.275v-1.094h-2.671c.035.755 0 8.65 0 8.65h2.671v-4.83c0-.24.018-.479.088-.65.193-.479.633-.974 1.371-.974.967 0 1.354.737 1.354 1.819v4.635h2.513z"/>
          </svg>
        </a>
      </div>
    </div>

    {/* Colonne 2 — Métiers 360 */}
    <div class="footer-col">
      <h3 class="footer-col-title">Métiers 360</h3>
      <ul class="footer-list">
        <li><a href="/a-propos">À propos</a></li>
        <li><a href="/pedagogie">Pédagogie & recherche</a></li>
        <li><a href="/references">Références</a></li>
      </ul>
    </div>

    {/* Colonne 3 — Découvrir */}
    <div class="footer-col">
      <h3 class="footer-col-title">Découvrir</h3>
      <ul class="footer-list">
        <li><a href="/accompagnement">Accompagnement</a></li>
        <li><a href="/visibilite-metiers">Visibilité métiers</a></li>
        <li><a href="/catalogue">Catalogue</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </div>

    {/* Colonne 4 — Contacter */}
    <div class="footer-col">
      <h3 class="footer-col-title">Contacter</h3>
      <ul class="footer-list">
        <li><a href="/espace-client">Espace client</a></li>
        <li><a href="/espace-client#support">Centre d'aide</a></li>
      </ul>
      <button class="footer-cta" data-open-contact-modal>
        Nous contacter
      </button>
    </div>

  </div>

  <div class="footer-bottom">
    <p class="footer-copyright">© 2026 Métiers 360 — Plus Editions SAS</p>
    <ul class="footer-legal-links">
      <li><a href="/mentions-legales">Mentions légales</a></li>
      <li><a href="/politique-confidentialite">Politique de confidentialité</a></li>
      <li><a href="/rse">RSE</a></li>
      <li><a href="/inclusion-accessibilite">Inclusion & accessibilité</a></li>
      <li><a href="/plan-du-site">Plan du site</a></li>
    </ul>
  </div>
</footer>

<style>
  /* ============================================
     FOOTER — fond navy, 4 colonnes desktop
     ============================================ */
  .site-footer {
    background: var(--m360-navy);
    color: rgba(255, 255, 255, 0.75);
    padding: var(--m360-space-14) 0 var(--m360-space-8);
    margin-top: var(--m360-space-16);
    position: relative;
    overflow: hidden;
  }

  /* Halos atmosphériques (cf. DS V0.12 §08) */
  .site-footer::before,
  .site-footer::after {
    content: '';
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
    pointer-events: none;
  }
  .site-footer::before {
    background: var(--m360-blue);
    top: -100px;
    left: -100px;
  }
  .site-footer::after {
    background: var(--m360-pink);
    bottom: -100px;
    right: -100px;
  }

  .footer-top,
  .footer-bottom {
    max-width: var(--m360-bp-desktop);
    margin: 0 auto;
    padding: 0 var(--m360-space-8);
    position: relative;
    z-index: 1;
  }

  /* ============================================
     FOOTER-TOP — grille 4 colonnes (1.5fr / 1fr / 1fr / 1fr)
     ============================================ */
  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--m360-space-10);
    margin-bottom: var(--m360-space-12);
  }

  /* Colonne identité */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-4);
  }

  .footer-logo {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: block;
  }

  .footer-signature {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    max-width: 280px;
  }

  .footer-socials {
    display: flex;
    gap: var(--m360-space-3);
    margin-top: var(--m360-space-2);
  }

  .social-link {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .social-link:hover {
    background: var(--m360-blue);
    color: #fff;
    text-decoration: none;
  }

  /* Colonnes navigation */
  .footer-col-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #45ABFF;
    margin: 0 0 var(--m360-space-5);
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--m360-space-3);
  }

  .footer-list a {
    color: rgba(255, 255, 255, 0.75);
    font-size: 14px;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-list a:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer-cta {
    margin-top: var(--m360-space-5);
    background: var(--m360-blue);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    padding: var(--m360-space-3) var(--m360-space-5);
    border-radius: var(--m360-radius-lg);
    border: none;
    cursor: pointer;
    box-shadow: var(--m360-shadow-blue);
    align-self: flex-start;
  }

  .footer-cta:hover {
    box-shadow: var(--m360-shadow-blue-hover);
  }

  /* ============================================
     FOOTER-BOTTOM — séparation + copyright + liens
     ============================================ */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--m360-space-6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--m360-space-4);
  }

  .footer-copyright {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  .footer-legal-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--m360-space-5);
    flex-wrap: wrap;
  }

  .footer-legal-links a {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
  }

  .footer-legal-links a:hover {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: underline;
  }

  /* ============================================
     RESPONSIVE
     968px : passage en 2 colonnes (cf. DS V0.12)
     640px : passage en 1 colonne, libellés légaux abrégés
     ============================================ */
  @media (max-width: 967px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: var(--m360-space-9);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 639px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--m360-space-8);
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--m360-space-3);
    }
    .footer-legal-links {
      gap: var(--m360-space-4);
    }
  }
</style>
